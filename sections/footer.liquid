            <img src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTPyJzlYHlS9JMX7q3IoxcaLC4msnGjQb6U0pr" alt="Mastercard" class="h-4 w-auto">
          </div>
          <div class="h-6 flex items-center justify-center hover:scale-[1.05] transition-transform" aria-label="PayPal">
