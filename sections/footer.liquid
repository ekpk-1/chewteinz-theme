          </div>
          <div class="h-6 flex items-center justify-center hover:scale-[1.06] transition-transform" aria-label="Shop Pay">
            <img src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTYeaFY3VgjT5dbGD4M8wqtOFR2HihnaclXvI1" alt="Shop Pay" class="h-4 w-auto">
          </div>
          <div class="h-6 flex items-center justify-center hover:scale-[1.07] transition-transform" aria-label="Union Pay">
            <img src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTYc3QtfVgjT5dbGD4M8wqtOFR2HihnaclXvI1" alt="Union Pay" class="h-4 w-auto">
          </div>
          <div class="h-6 flex items-center justify-center hover:scale-[1.08] transition-transform" aria-label="Visa">
