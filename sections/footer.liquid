        <p class="text-sm sm:text-base text-gray-400 font-body">
          The smarter way to snack.
        </p>
      </div>

      <div>
        <h4 class="font-display font-bold text-base sm:text-lg mb-3 sm:mb-4">Shop</h4>
        <ul class="space-y-2 font-body text-sm sm:text-base">
          <li>
            <a href="{{ routes.all_products_collection_url }}" class="text-gray-400 hover:text-white transition-colors">All Products</a>
          </li>
          <li>
            <a href="{{ routes.all_products_collection_url }}" class="text-gray-400 hover:text-white transition-colors">Best Sellers</a>
          </li>
        </ul>
      </div>

      <div>
