          <li><a href="/pages/privacy" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/pages/shipping" class="text-gray-400 hover:text-white transition-colors">Shipping Policy</a></li>
          <li><a href="/pages/terms" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
