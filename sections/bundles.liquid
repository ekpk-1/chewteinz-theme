<section class="ct-section bundles-section" id="ct-bundles">
  <div class="ct-container">
    <div class="section-head section-head--center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ct-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="bundle-grid">
      {%- for block in section.blocks -%}
        {%- assign bundle_product = block.settings.product -%}
        {%- assign bundle_variant = bundle_product.selected_or_first_available_variant -%}
        {%- assign manual_variant_id = block.settings.variant_id | strip -%}
        {%- assign bundle_title = block.settings.title -%}
        {%- if bundle_title == blank and bundle_product != blank -%}
          {%- assign bundle_title = bundle_product.title -%}
        {%- endif -%}
        {%- assign bundle_price = block.settings.price_label -%}
        {%- if bundle_price == blank and bundle_product != blank -%}
          {%- assign bundle_price = bundle_product.price | money -%}
        {%- endif -%}
        {%- assign fallback_asset = blank -%}
        {%- assign bundle_title_downcase = bundle_title | downcase -%}
        {%- if bundle_title_downcase contains '10' -%}
          {%- assign fallback_asset = 'bag-mango-10pack.png' -%}
        {%- elsif bundle_title_downcase contains '3-pack' or bundle_title_downcase contains '3 pack' -%}
          {%- assign fallback_asset = 'bag-mango-3pack.png' -%}
        {%- else -%}
          {%- assign fallback_asset = 'bag-mango.png' -%}
        {%- endif -%}

        <article class="bundle-card" {{ block.shopify_attributes }}>
          {%- if block.settings.save_label != blank -%}
            <span class="bundle-card__save">{{ block.settings.save_label }}</span>
          {%- endif -%}
          <div class="bundle-card__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 420 }} 420w, {{ block.settings.image | image_url: width: 620 }} 620w, {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 900px) 88vw, 360px"
                alt="{{ block.settings.image.alt | default: bundle_title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy">
            {%- elsif fallback_asset != blank -%}
              <img
                src="{{ fallback_asset | asset_url }}"
                sizes="(max-width: 900px) 88vw, 360px"
                alt="{{ bundle_title | escape }}"
                width="1200"
                height="900"
                loading="lazy">
            {%- elsif bundle_product.featured_image -%}
              <img
                src="{{ bundle_product.featured_image | image_url: width: 800 }}"
                srcset="{{ bundle_product.featured_image | image_url: width: 420 }} 420w, {{ bundle_product.featured_image | image_url: width: 620 }} 620w, {{ bundle_product.featured_image | image_url: width: 800 }} 800w"
                sizes="(max-width: 900px) 88vw, 360px"
                alt="{{ bundle_product.title | escape }}"
                width="{{ bundle_product.featured_image.width }}"
                height="{{ bundle_product.featured_image.height }}"
                loading="lazy">
            {%- else -%}
              <span class="bundle-card__placeholder">{{ forloop.index }}</span>
            {%- endif -%}
          </div>
          <div class="bundle-card__body">
            <h3>{{ bundle_title }}</h3>
            {%- if block.settings.description != blank -%}
              <p>{{ block.settings.description }}</p>
            {%- endif -%}
            <div class="bundle-card__price">
              <span>{{ bundle_price }}</span>
              {%- if block.settings.price_suffix != blank -%}
                <small>{{ block.settings.price_suffix }}</small>
              {%- endif -%}
            </div>

            {%- if bundle_product != blank and bundle_product.available -%}
              <button
                type="button"
                class="btn btn--block bundle-card__button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ bundle_variant.id }})">
                {{ block.settings.button_label | default: 'Add to cart' }}
              </button>
            {%- elsif manual_variant_id != blank -%}
              <button
                type="button"
                class="btn btn--block bundle-card__button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ manual_variant_id | json }})">
                {{ block.settings.button_label | default: 'Add to cart' }}
              </button>
            {%- else -%}
              <button
                type="button"
                class="btn btn--ghost btn--block bundle-card__button"
                onclick="window.modals && window.modals.openSubscribe({{ bundle_title | json }})">
                {{ block.settings.waitlist_button_label | default: 'Join the waitlist' }}
              </button>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Bundles",
    "settings": [
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Stock up and save"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Buy more, save more."
      }, {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
        "default": "Mango Madness ships today. Grab a multipack and lock in up to 30% off."
      }
    ],
    "blocks": [
      {
        "type": "bundle",
        "name": "Bundle",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Shopify product"
          },
          {
            "type": "text",
            "id": "variant_id",
            "label": "Manual variant ID",
            "info": "Optional fallback if this bundle is a variant rather than a separate product."
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Mango 3-Pack"
          }, {
            "type": "text",
            "id": "save_label",
            "label": "Save label",
            "default": "Save 15%"
          }, {
            "type": "text",
            "id": "description",
            "label": "Description",
            "default": "3 bags, 180g each"
          }, {
            "type": "text",
            "id": "price_label",
            "label": "Price label",
            "default": "$65.00"
          }, {
            "type": "text",
            "id": "price_suffix",
            "label": "Price suffix",
            "default": "AUD"
          }, {
            "type": "text",
            "id": "button_label",
            "label": "Button label",
            "default": "Add to cart"
          }, {
            "type": "text",
            "id": "waitlist_button_label",
            "label": "Waitlist button label",
            "default": "Join the waitlist"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Bundles",
        "blocks": [
          {
            "type": "bundle",
            "settings": {
              "title": "Single Bag",
              "save_label": "",
              "description": "180g, 20g protein per serve",
              "price_label": "$25.00"
            }
          }, {
            "type": "bundle",
            "settings": {
              "title": "Mango 3-Pack",
              "save_label": "Save 15%",
              "description": "3 bags, 180g each",
              "price_label": "$65.00"
            }
          }, {
            "type": "bundle",
            "settings": {
              "title": "Mango 10-Pack",
              "save_label": "Save 30%",
              "description": "10 bags, stock up",
              "price_label": "$175.00"
            }
          }
        ]
      }
    ]
  }
{% endschema %}