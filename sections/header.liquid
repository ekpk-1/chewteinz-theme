{%- liquid
  assign current_path = request.path
  assign shop_anchor = '#ct-shop'
  assign why_anchor = '#ct-why'
  assign nutrition_anchor = '#ct-nutrition'
  assign faq_anchor = '#ct-faq'
  if current_path != '/'
    assign shop_anchor = '/#ct-shop'
    assign why_anchor = '/#ct-why'
    assign nutrition_anchor = '/#ct-nutrition'
    assign faq_anchor = '/#ct-faq'
  endif
-%}

<header class="site-header" id="site-header">
  <div class="ct-container site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__brand" aria-label="{{ shop.name }} home">
      <img
        src="{{ 'chewteinz-logo.png' | asset_url }}"
        alt="{{ shop.name }}"
        class="h-10 sm:h-11 md:h-12 w-auto"
        width="180"
        height="48"
        loading="eager">
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a class="nav-link" href="{{ shop_anchor }}">Shop</a>
      <a class="nav-link" href="{{ why_anchor }}">Why Us</a>
      <a class="nav-link" href="{{ nutrition_anchor }}">Nutrition</a>
      <a class="nav-link" href="{{ faq_anchor }}">FAQ</a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href="{{ shop_anchor }}" class="site-header__shop">Shop</a>
      <button
        type="button"
        class="icon-btn icon-btn--filled"
        onclick="window.cartDrawer && window.cartDrawer.open()"
        aria-label="Open cart">
        <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-cart"/></svg>
        <span class="badge-count cart-count-badge {% if cart.item_count == 0 %}hidden{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </button>

      <button
        type="button"
        class="icon-btn md:hidden"
        data-menu-toggle
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open menu">
        <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-menu"/></svg>
      </button>
    </div>
  </div>
</header>

{%- comment -%} Mobile menu — slides in from the right on small screens {%- endcomment -%}
<div
  class="fixed inset-x-0 bottom-0 top-[calc(40px+64px)] sm:top-[calc(48px+76px)] z-30 bg-chewteinz-cream px-6 py-10 translate-x-full transition-transform duration-300 ease-out md:hidden"
  id="mobile-menu"
  aria-hidden="true">
  <ul class="flex flex-col gap-2">
    <li><a class="block py-3 border-b border-chewteinz-ink/10 font-display text-3xl font-semibold" href="{{ shop_anchor }}">Shop</a></li>
    <li><a class="block py-3 border-b border-chewteinz-ink/10 font-display text-3xl font-semibold" href="{{ why_anchor }}">Why Us</a></li>
    <li><a class="block py-3 border-b border-chewteinz-ink/10 font-display text-3xl font-semibold" href="{{ nutrition_anchor }}">Nutrition</a></li>
    <li><a class="block py-3 border-b border-chewteinz-ink/10 font-display text-3xl font-semibold" href="{{ faq_anchor }}">FAQ</a></li>
    <li><a class="block py-3 border-b border-chewteinz-ink/10 font-display text-3xl font-semibold" href="/pages/contact">Contact</a></li>
  </ul>
</div>

<style>
  #mobile-menu.is-open { transform: translateX(0); }
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
