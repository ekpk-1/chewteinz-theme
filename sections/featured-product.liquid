{%- liquid
  assign featured = section.settings.product
  if featured == blank
    assign featured = collections.all.products.first
  endif

  assign accent_word = section.settings.accent_word | default: 'Madness'
  assign heading = section.settings.heading
-%}

<section class="ct-section featured-section" id="ct-nutrition">
  <div class="ct-container">
    {%- if featured != blank -%}
      <div class="featured__inner">
        <div class="featured__media reveal" data-delay="1">
          {%- if section.settings.nutrition_image != blank -%}
            <img
              src="{{ section.settings.nutrition_image | image_url: width: 1100 }}"
              srcset="{{ section.settings.nutrition_image | image_url: width: 560 }} 560w, {{ section.settings.nutrition_image | image_url: width: 820 }} 820w, {{ section.settings.nutrition_image | image_url: width: 1100 }} 1100w"
              sizes="(max-width: 900px) 92vw, 560px"
              alt="{{ section.settings.nutrition_image.alt | default: 'Mango Madness nutrition information' | escape }}"
              loading="lazy"
              width="{{ section.settings.nutrition_image.width }}"
              height="{{ section.settings.nutrition_image.height }}">
          {%- else -%}
            <img
              src="{{ 'nutrition-panel.png' | asset_url }}"
              sizes="(max-width: 900px) 92vw, 560px"
              alt="Mango Madness nutrition information"
              loading="lazy"
              width="768"
              height="1024">
          {%- endif -%}
        </div>

        <div class="featured__copy reveal" data-delay="2">
          {%- if section.settings.eyebrow != blank -%}
            <p class="ct-eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h2>
            {%- if heading contains accent_word and accent_word != blank -%}
              {%- assign parts = heading | split: accent_word -%}
              {{ parts[0] }}<em>{{ accent_word }}</em>
              {{ parts[1] }}
            {%- else -%}
              {{ heading }}
            {%- endif -%}
          </h2>

          <p class="featured__desc">
            {%- if section.settings.description != blank -%}
              {{ section.settings.description }}
            {%- else -%}
              {{ featured.description | strip_html | truncate: 220 }}
            {%- endif -%}
          </p>

          <div class="featured__price">
            <span>{{ featured.price | money }}</span>
            <small>{{ section.settings.price_meta | default: 'AUD · 180g bag · 20g protein/serve' }}</small>
          </div>

          <div class="macro-strip" aria-label="Nutrition highlights">
            <div>
              <strong>{{ section.settings.macro_1_value | default: '20g' }}</strong>
              <span>{{ section.settings.macro_1_label | default: 'Protein' }}</span>
            </div>
            <div>
              <strong>{{ section.settings.macro_2_value | default: '0g' }}</strong>
              <span>{{ section.settings.macro_2_label | default: 'Sugar' }}</span>
            </div>
            <div>
              <strong>{{ section.settings.macro_3_value | default: '108' }}</strong>
              <span>{{ section.settings.macro_3_label | default: 'Calories' }}</span>
            </div>
            <div>
              <strong>{{ section.settings.macro_4_value | default: '180g' }}</strong>
              <span>{{ section.settings.macro_4_label | default: 'Net wt' }}</span>
            </div>
          </div>

          <div class="featured__ctas">
            {%- if featured.available -%}
              <button
                type="button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ featured.selected_or_first_available_variant.id }})"
                class="btn btn--lg btn--shadow">
                Add to cart
                <span class="btn__arrow">
                  <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
                </span>
              </button>
            {%- else -%}
              <button
                type="button"
                class="btn btn--lg"
                disabled
                style="opacity: 0.5; cursor: not-allowed;">
                Sold Out
              </button>
            {%- endif -%}

          </div>

          {%- if section.settings.show_nutrition_link -%}
            <button
              type="button"
              onclick="window.modals && window.modals.openNutrition('{{ featured.title | escape }}')"
              class="featured__text-link">
              <svg class="w-4 h-4" aria-hidden="true"><use href="#i-info" /></svg>
              Nutritional facts
            </button>
          {%- endif -%}
        </div>
      </div>

    {%- endif -%}
  </div>
</section>

{% schema %}
  {
    "name": "Featured Product",
    "settings": [
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Featured · available now"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Mango Madness."
      },
      {
        "type": "text",
        "id": "accent_word",
        "label": "Accent word",
        "info": "Word inside the heading rendered as the visual accent.",
        "default": "Madness"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading (legacy)",
        "info": "Kept for back-compat; not rendered in the new design.",
        "default": "Each bag contains 60g of protein"
      }, {
        "type": "textarea",
        "id": "description",
        "label": "Description override",
        "info": "Leave blank to use the product's own description.",
        "default": "Tropical mango wrapped in a pillowy plant-protein gummy. 20g of pea and rice protein per pack, zero added sugar, and the same hit of sunshine you remember."
      }, {
        "type": "image_picker",
        "id": "nutrition_image",
        "label": "Nutrition image",
        "info": "Optional nutrition panel image. Falls back to the product image."
      }, {
        "type": "text",
        "id": "price_meta",
        "label": "Price meta",
        "default": "AUD · 180g bag · 20g protein/serve"
      }, {
        "type": "product",
        "id": "product",
        "label": "Featured Product"
      }, {
        "type": "text",
        "id": "macro_1_value",
        "label": "Macro 1 value",
        "default": "20g"
      }, {
        "type": "text",
        "id": "macro_1_label",
        "label": "Macro 1 label",
        "default": "Protein"
      }, {
        "type": "text",
        "id": "macro_2_value",
        "label": "Macro 2 value",
        "default": "0g"
      }, {
        "type": "text",
        "id": "macro_2_label",
        "label": "Macro 2 label",
        "default": "Sugar"
      }, {
        "type": "text",
        "id": "macro_3_value",
        "label": "Macro 3 value",
        "default": "108"
      }, {
        "type": "text",
        "id": "macro_3_label",
        "label": "Macro 3 label",
        "default": "Calories"
      }, {
        "type": "text",
        "id": "macro_4_value",
        "label": "Macro 4 value",
        "default": "180g"
      }, {
        "type": "text",
        "id": "macro_4_label",
        "label": "Macro 4 label",
        "default": "Net wt"
      }, {
        "type": "checkbox",
        "id": "show_nutrition_link",
        "label": "Show nutritional facts link",
        "default": true
      }
    ]
  }
{% endschema %}