{%- assign featured = section.settings.product -%}
{%- if featured == blank -%}
  {%- assign featured = collections.all.products.first -%}
{%- endif -%}

<section class="py-12 sm:py-16 md:py-20 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold text-center mb-4 bg-gradient-to-r from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple bg-clip-text text-transparent px-4">
      {{ section.settings.heading }}
    </h2>
    <p class="text-base sm:text-lg md:text-xl text-gray-600 text-center mb-8 sm:mb-12 md:mb-16 font-body px-4">
      {{ section.settings.subheading }}
    </p>

    {% if featured != blank %}
      <div class="flex justify-center">
        <div class="max-w-md w-full">
          <div class="group relative bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="h-48 sm:h-56 md:h-64 bg-gradient-to-br from-pink-400 to-purple-500 flex items-center justify-center relative overflow-hidden">
              {% if featured.featured_image %}
                <img
                  src="{{ featured.featured_image | image_url: width: 600 }}"
                  alt="{{ featured.title | escape }}"
                  class="w-full h-full object-cover transform scale-105 group-hover:scale-[1.15] transition-transform duration-500"
                  loading="lazy"
                  width="600"
                  height="600">
              {% endif %}

              <div class="absolute top-2 right-2 sm:top-3 sm:right-3 md:top-4 md:right-4 bg-white/90 backdrop-blur-sm rounded-full px-3 py-1 sm:px-4 sm:py-2 font-display font-bold text-sm sm:text-base text-gray-800">
                {{ featured.price | money }}
              </div>

              <span class="absolute top-2 left-2 sm:top-3 sm:left-3 md:top-4 md:left-4 text-white opacity-0 group-hover:opacity-100 transition-opacity animate-sparkle">{% render 'icon'
, icon: 'sparkles'
, size: 16 %}</span>
              <span class="absolute bottom-2 right-2 sm:bottom-3 sm:right-3 md:bottom-4 md:right-4 text-white opacity-0 group-hover:opacity-100 transition-opacity animate-sparkle" style="animation-delay:0.3s">{% render 'icon'
, icon: 'sparkles'
, size: 16 %}</span>
            </div>

            <div class="p-4 sm:p-5 md:p-6">
              <h3 class="text-xl sm:text-2xl font-display font-bold text-gray-800 mb-2">
                {{ featured.title }}
              </h3>
              <p class="text-sm sm:text-base text-gray-600 font-body mb-3 sm:mb-4">{{ featured.description | strip_html | truncate: 120 }}</p>

              <div class="flex flex-col gap-2">
                {% if featured.available %}
                  <button
                    type="button"
                    onclick="window.cartDrawer.addItem({{ featured.selected_or_first_available_variant.id }})"
                    class="w-full bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink text-white font-display font-semibold py-2 sm:py-3 text-sm sm:text-base rounded-full hover:scale-105 transition-transform flex items-center justify-center gap-2">
                    {% render 'icon'
                      , icon: 'shopping-cart'
                      , size: 16 %}
                    Order Now!
                  </button>
                {% else %}
                  <button
                    type="button"
                    disabled
                    class="w-full bg-gray-300 text-gray-500 font-display font-semibold py-2 sm:py-3 text-sm sm:text-base rounded-full cursor-not-allowed flex items-center justify-center gap-2">
                    Sold Out
                  </button>
                {% endif %}
                <div class="flex gap-2">
                  <button
                    type="button"
                    onclick="window.modals.openNutrition('{{ featured.title | escape }}')"
                    class="flex-1 bg-gray-100 text-gray-700 font-display font-semibold py-2 sm:py-2.5 text-sm sm:text-base rounded-full hover:bg-gray-200 transition-colors flex items-center justify-center gap-2">
                    {% render 'icon'
                      , icon: 'info'
                      , size: 16 %}
                    Learn More
                  </button>
                  <a href="{{ routes.all_products_collection_url }}" class="flex-1 bg-gray-100 text-gray-700 font-display font-semibold py-2 sm:py-2.5 text-sm sm:text-base rounded-full hover:bg-gray-200 transition-colors text-center">
                    View
                  </a>
                </div>
              </div>
            </div>

            <div class="absolute inset-0 border-4 border-transparent group-hover:border-white/50 rounded-3xl transition-all pointer-events-none"></div>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="text-center mt-8 sm:mt-10 md:mt-12 px-4">
      <a href="{{ routes.all_products_collection_url }}" class="inline-block px-6 py-3 sm:px-8 sm:py-4 bg-gradient-to-r from-chewteinz-yellow to-chewteinz-orange text-gray-800 font-display font-bold text-lg sm:text-xl rounded-full shadow-lg hover:scale-105 transition-transform w-full sm:w-auto max-w-xs sm:max-w-none text-center">
        View All Products
      </a>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Featured Product",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Choose Your Flavor"
      }, {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Each bag contains 60g of protein"
      }, {
        "type": "product",
        "id": "product",
        "label": "Featured Product"
      }
    ]
  }
{% endschema %}