{%- liquid
  assign featured = section.settings.product
  if featured == blank
    assign featured = collections.all.products.first
  endif

  assign accent_word = section.settings.accent_word | default: 'Madness'
  assign heading = section.settings.heading

  assign rating_value = section.settings.rating_value | default: '4.9'
  assign rating_count = section.settings.rating_count | default: '247'
-%}

<section class="ct-section featured-section" id="shop">
  <div class="ct-container">
    {%- if featured != blank -%}
      <div class="featured__inner">
        <div class="featured__media reveal" data-delay="1">
          <span class="price-tag">{{ featured.price | money }}</span>
          {%- if featured.featured_image -%}
            <img
              src="{{ featured.featured_image | image_url: width: 800 }}"
              srcset="
                {{ featured.featured_image | image_url: width: 400 }} 400w,
                {{ featured.featured_image | image_url: width: 600 }} 600w,
                {{ featured.featured_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 820px) 90vw, 520px"
              alt="{{ featured.title | escape }}"
              loading="lazy"
              width="800"
              height="800">
          {%- endif -%}
        </div>

        <div class="featured__copy reveal" data-delay="2">
          <h2>
            {%- if heading contains accent_word and accent_word != blank -%}
              {%- assign parts = heading | split: accent_word -%}
              {{ parts[0] }}<em>{{ accent_word }}</em>
              {{ parts[1] }}
            {%- else -%}
              {{ heading }}
            {%- endif -%}
          </h2>

          <div class="featured__rating">
            <span class="stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg class="w-4 h-4"><use href="#i-star" /></svg>
              {%- endfor -%}
            </span>
            <span>{{ rating_value }} &middot; {{ rating_count }} reviews</span>
          </div>

          <p class="featured__desc">
            {%- if section.settings.description != blank -%}
              {{ section.settings.description }}
            {%- else -%}
              {{ featured.description | strip_html | truncate: 220 }}
            {%- endif -%}
          </p>

          <div class="featured__price">{{ featured.price | money }}</div>

          {%- comment -%}
            Flavour swatches — derived from the first product option that has
            multiple values (typically "Flavour" or "Variant"). Falls back to
            three brand swatches if the product hasn't been wired up yet so
            the section never looks empty during setup.
          {%- endcomment -%}
          {%- assign flavour_option = blank -%}
          {%- for opt in featured.options_with_values -%}
            {%- if opt.values.size > 1 and flavour_option == blank -%}
              {%- assign flavour_option = opt -%}
            {%- endif -%}
          {%- endfor -%}

          <div class="mb-6">
            <span class="ct-eyebrow block mb-3">
              {% if flavour_option %}
                {{ flavour_option.name }}{% else %}Flavours{% endif %}
            </span>
            <div class="swatches">
              {%- if flavour_option -%}
                {%- for v in flavour_option.values -%}
                  {%- assign vlc = v | downcase -%}
                  {%- assign swatch_color = 'var(--c-yellow)' -%}
                  {%- if vlc contains 'mango' or vlc contains 'orange' -%}
                    {%- assign swatch_color = 'var(--c-orange)' -%}
                  {%- elsif vlc contains 'watermelon' or vlc contains 'pink' or vlc contains 'strawberry' -%}
                    {%- assign swatch_color = 'var(--c-pink)' -%}
                  {%- elsif vlc contains 'blue' or vlc contains 'berry' -%}
                    {%- assign swatch_color = 'var(--c-blue)' -%}
                  {%- elsif vlc contains 'grape' or vlc contains 'purple' -%}
                    {%- assign swatch_color = 'var(--c-purple)' -%}
                  {%- endif -%}
                  <button
                    type="button"
                    class="swatch{% if forloop.first %} is-active{% endif %}"
                    aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                    style="--swatch-color: {{ swatch_color }}">
                    <span class="swatch__dot"></span>
                    {{ v }}
                  </button>
                {%- endfor -%}
              {%- else -%}
                <button
                  type="button"
                  class="swatch is-active"
                  aria-pressed="true"
                  style="--swatch-color: var(--c-orange)">
                  <span class="swatch__dot"></span>
                  Mango</button>
                <button
                  type="button"
                  class="swatch"
                  aria-pressed="false"
                  style="--swatch-color: var(--c-pink)">
                  <span class="swatch__dot"></span>
                  Watermelon</button>
                <button
                  type="button"
                  class="swatch"
                  aria-pressed="false"
                  style="--swatch-color: var(--c-blue)">
                  <span class="swatch__dot"></span>
                  Blueberry</button>
              {%- endif -%}
            </div>
          </div>

          <div class="featured__ctas">
            {%- if featured.available -%}
              <button
                type="button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ featured.selected_or_first_available_variant.id }})"
                class="btn btn--gradient btn--lg">
                Add to cart
                <span class="btn__arrow">
                  <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
                </span>
              </button>
            {%- else -%}
              <button
                type="button"
                class="btn btn--lg"
                disabled
                style="opacity: 0.5; cursor: not-allowed;">
                Sold Out
              </button>
            {%- endif -%}

          </div>

          {%- if section.settings.show_nutrition_link -%}
            <button
              type="button"
              onclick="window.modals && window.modals.openNutrition('{{ featured.title | escape }}')"
              class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-chewteinz-ink-soft hover:text-chewteinz-ink transition-colors">
              <svg class="w-4 h-4" aria-hidden="true"><use href="#i-info" /></svg>
              Nutritional facts
            </button>
          {%- endif -%}
        </div>
      </div>

      <div class="text-center mt-12 px-4">
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--gradient-alt btn--lg">
          View all products
          <span class="btn__arrow">
            <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
          </span>
        </a>
      </div>

      {%- if section.settings.show_reviews -%}
        <div class="mt-16">
          {% render 'product-reviews'
            , product: featured %}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
  {
    "name": "Featured Product",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Mango Madness."
      },
      {
        "type": "text",
        "id": "accent_word",
        "label": "Accent word",
        "info": "Word inside the heading rendered as the visual accent.",
        "default": "Madness"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading (legacy)",
        "info": "Kept for back-compat; not rendered in the new design.",
        "default": "Each bag contains 60g of protein"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description override",
        "info": "Leave blank to use the product's own description.",
        "default": "Tropical mango wrapped in a pillowy plant-protein gummy. 20g of pea and rice protein per pack, zero added sugar, and the same hit of sunshine you remember."
      }, {
        "type": "text",
        "id": "rating_value",
        "label": "Rating value",
        "default": "4.9"
      }, {
        "type": "text",
        "id": "rating_count",
        "label": "Rating count",
        "default": "247"
      }, {
        "type": "product",
        "id": "product",
        "label": "Featured Product"
      }, {
        "type": "checkbox",
        "id": "show_nutrition_link",
        "label": "Show nutritional facts link",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_reviews",
        "label": "Show reviews under product",
        "default": true,
        "info": "Renders the reviews section. Compatible with Shopify Product Reviews, Judge.me and Loox apps."
      }
    ]
  }
{% endschema %}