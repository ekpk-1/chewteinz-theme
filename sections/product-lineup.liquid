<section class="ct-section lineup-section" id="ct-shop">
  <div class="ct-container">
    <div class="section-head section-head--center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ct-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="lineup-grid">
      {%- for block in section.blocks -%}
        {%- assign card_product = block.settings.product -%}
        {%- assign card_variant = card_product.selected_or_first_available_variant -%}
        {%- assign card_title = block.settings.title -%}
        {%- if card_title == blank and card_product != blank -%}
          {%- assign card_title = card_product.title -%}
        {%- endif -%}
        {%- assign card_price = block.settings.price_label -%}
        {%- if card_price == blank and card_product != blank -%}
          {%- assign card_price = card_product.price | money -%}
        {%- endif -%}
        {%- assign card_image = block.settings.image -%}
        {%- assign fallback_asset = blank -%}
        {%- assign card_title_downcase = card_title | downcase -%}
        {%- if card_title_downcase contains 'watermelon' -%}
          {%- assign fallback_asset = 'bag-watermelon.png' -%}
        {%- elsif card_title_downcase contains 'blueberry' -%}
          {%- assign fallback_asset = 'bag-blueberry.png' -%}
        {%- elsif card_title_downcase contains 'travel' -%}
          {%- assign fallback_asset = 'bag-mango-travel.png' -%}
        {%- else -%}
          {%- assign fallback_asset = 'bag-mango.png' -%}
        {%- endif -%}
        {%- assign card_available = false -%}
        {%- if block.settings.force_coming_soon == false and card_product != blank and card_product.available -%}
          {%- assign card_available = true -%}
        {%- endif -%}

        <article class="lineup-card" style="--lineup-soft: {{ block.settings.soft_color }}; --lineup-deep: {{ block.settings.deep_color }};" {{ block.shopify_attributes }}>
          <div class="lineup-card__media">
            {%- if block.settings.badge != blank -%}
              <span class="lineup-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            {%- if card_image != blank -%}
              <img
                src="{{ card_image | image_url: width: 700 }}"
                srcset="{{ card_image | image_url: width: 360 }} 360w, {{ card_image | image_url: width: 520 }} 520w, {{ card_image | image_url: width: 700 }} 700w"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_image.alt | default: card_title | escape }}"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                loading="lazy">
            {%- elsif fallback_asset != blank -%}
              <img
                src="{{ fallback_asset | asset_url }}"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_title | escape }}"
                width="874"
                height="1184"
                loading="lazy">
            {%- elsif card_product.featured_image -%}
              <img
                src="{{ card_product.featured_image | image_url: width: 700 }}"
                srcset="{{ card_product.featured_image | image_url: width: 360 }} 360w, {{ card_product.featured_image | image_url: width: 520 }} 520w, {{ card_product.featured_image | image_url: width: 700 }} 700w"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_product.title | escape }}"
                width="{{ card_product.featured_image.width }}"
                height="{{ card_product.featured_image.height }}"
                loading="lazy">
            {%- else -%}
              <span class="lineup-card__placeholder">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            {%- endif -%}
          </div>

          <div class="lineup-card__body">
            <h3>{{ card_title }}</h3>
            <p class="lineup-card__meta">
              {%- if block.settings.protein_label != blank -%}
                {{ block.settings.protein_label }}
                {%- if card_price != blank -%} · {%- endif -%}
              {%- endif -%}
              {{ card_price }}
            </p>
            {%- if block.settings.description != blank -%}
              <p class="lineup-card__desc">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if card_available -%}
              <button
                type="button"
                class="btn btn--block lineup-card__button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ card_variant.id }})">
                {{ block.settings.available_button_label | default: 'Add to cart' }}
              </button>
            {%- else -%}
              <button
                type="button"
                class="btn btn--ghost btn--block lineup-card__button"
                onclick="window.modals && window.modals.openSubscribe({{ card_title | json }})">
                {{ block.settings.waitlist_button_label | default: 'Join the waitlist' }}
              </button>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product lineup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The full lineup"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the lineup."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify product" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Available now" },
        { "type": "text", "id": "protein_label", "label": "Protein label", "default": "60g protein" },
        { "type": "text", "id": "price_label", "label": "Price label" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "color", "id": "soft_color", "label": "Soft background", "default": "#F6E1C6" },
        { "type": "color", "id": "deep_color", "label": "Deep accent", "default": "#A06E37" },
        { "type": "checkbox", "id": "force_coming_soon", "label": "Force coming soon", "default": false },
        { "type": "text", "id": "available_button_label", "label": "Available button label", "default": "Add to cart" },
        { "type": "text", "id": "waitlist_button_label", "label": "Waitlist button label", "default": "Join the waitlist" }
