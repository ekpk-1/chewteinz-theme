<section class="ct-section lineup-section" id="ct-shop">
  <div class="ct-container">
    <div class="section-head section-head--center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ct-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="lineup-grid">
      {%- for block in section.blocks -%}
        {%- assign card_product = block.settings.product -%}
        {%- assign card_variant = card_product.selected_or_first_available_variant -%}
        {%- assign card_title = block.settings.title -%}
        {%- if card_title == blank and card_product != blank -%}
          {%- assign card_title = card_product.title -%}
        {%- endif -%}
        {%- assign card_price = block.settings.price_label -%}
        {%- if card_price == blank and card_product != blank -%}
          {%- assign card_price = card_product.price | money -%}
        {%- endif -%}
        {%- assign card_image = block.settings.image -%}
        {%- assign fallback_asset = blank -%}
        {%- assign card_title_downcase = card_title | downcase -%}
        {%- if card_title_downcase contains 'watermelon' -%}
          {%- assign fallback_asset = 'bag-watermelon.png' -%}
        {%- elsif card_title_downcase contains 'blueberry' -%}
          {%- assign fallback_asset = 'bag-blueberry.png' -%}
        {%- elsif card_title_downcase contains 'travel' -%}
          {%- assign fallback_asset = 'bag-mango-travel.png' -%}
        {%- else -%}
          {%- assign fallback_asset = 'bag-mango.png' -%}
        {%- endif -%}
        {%- assign card_available = false -%}
        {%- if block.settings.force_coming_soon == false and card_product != blank and card_product.available -%}
          {%- assign card_available = true -%}
        {%- endif -%}
        {%- assign card_url = blank -%}
        {%- if card_product != blank -%}
          {%- assign card_url = card_product.url -%}
        {%- endif -%}

        <article class="lineup-card" style="--lineup-soft: {{ block.settings.soft_color }}; --lineup-deep: {{ block.settings.deep_color }};" {{ block.shopify_attributes }}>
          {%- if card_url != blank -%}
            <a class="lineup-card__media" href="{{ card_url }}" aria-label="View {{ card_title | escape }}">
          {%- else -%}
            <div class="lineup-card__media">
          {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="lineup-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            {%- if card_image != blank -%}
              <img
                src="{{ card_image | image_url: width: 700 }}"
                srcset="{{ card_image | image_url: width: 360 }} 360w, {{ card_image | image_url: width: 520 }} 520w, {{ card_image | image_url: width: 700 }} 700w"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_image.alt | default: card_title | escape }}"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                loading="lazy">
            {%- elsif fallback_asset != blank -%}
              <img
                src="{{ fallback_asset | asset_url }}"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_title | escape }}"
                width="874"
                height="1184"
                loading="lazy">
            {%- elsif card_product.featured_image -%}
              <img
                src="{{ card_product.featured_image | image_url: width: 700 }}"
                srcset="{{ card_product.featured_image | image_url: width: 360 }} 360w, {{ card_product.featured_image | image_url: width: 520 }} 520w, {{ card_product.featured_image | image_url: width: 700 }} 700w"
                sizes="(max-width: 700px) 82vw, 280px"
                alt="{{ card_product.title | escape }}"
                width="{{ card_product.featured_image.width }}"
                height="{{ card_product.featured_image.height }}"
                loading="lazy">
            {%- else -%}
              <span class="lineup-card__placeholder">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            {%- endif -%}
            <span class="lineup-card__view-pill">{{ block.settings.view_label | default: 'View →' }}</span>
          {%- if card_url != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}

          <div class="lineup-card__body">
            <h3>{{ card_title }}</h3>
            <p class="lineup-card__meta">
              {%- if block.settings.protein_label != blank -%}
                {{ block.settings.protein_label }}
                {%- if card_price != blank -%} · {%- endif -%}
              {%- endif -%}
              {{ card_price }}
            </p>
            {%- if block.settings.description != blank -%}
              <p class="lineup-card__desc">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if card_available -%}
              <button
                type="button"
                class="btn btn--block lineup-card__button"
                onclick="window.cartDrawer && window.cartDrawer.addItem({{ card_variant.id }})">
                {{ block.settings.available_button_label | default: 'Add to cart' }}
              </button>
            {%- else -%}
              <a
                href="#ct-waitlist"
                class="btn btn--ghost btn--block lineup-card__button">
                {{ block.settings.waitlist_button_label | default: 'Join the waitlist' }}
              </a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .lineup-section .ct-container {
    max-width: 1240px;
  }

  .lineup-section .lineup-grid {
    grid-template-columns: repeat(4, minmax(240px, 1fr));
    gap: 20px;
    align-items: stretch;
  }

  .lineup-section .lineup-card {
    width: 100%;
    min-width: 0;
    border: 1.5px solid var(--c-ink);
    border-radius: 26px;
    background: var(--c-paper);
    box-shadow: 6px 6px 0 var(--c-ink);
  }

  .lineup-section .lineup-card__media {
    height: 280px;
    min-height: 0;
    padding: 30px 20px 18px;
    border-bottom: 1.5px solid rgba(58, 51, 44, .1);
    background: var(--lineup-soft);
    overflow: hidden;
  }

  .lineup-section .lineup-card__media img {
    position: relative;
    z-index: 1;
    width: auto;
    height: 188px;
    max-width: 74%;
    max-height: none;
    object-fit: contain;
    filter: drop-shadow(0 14px 18px rgba(58, 51, 44, .2));
  }

  .lineup-section .lineup-card__badge {
    top: 14px;
    left: 14px;
    padding: 5px 12px;
    font-size: 12px;
    letter-spacing: .06em;
  }

  .lineup-section .lineup-card__body {
    padding: 22px 24px 26px;
    gap: 6px;
  }

  .lineup-section .lineup-card__body h3 {
    font-size: 1.5rem;
    line-height: 1.1;
  }

  .lineup-section .lineup-card__meta {
    color: var(--lineup-deep);
    font-size: 14px;
    font-weight: 800;
  }

  .lineup-section .lineup-card__desc {
    margin-top: 4px;
    color: var(--c-ink-soft);
    font-size: .95rem;
    line-height: 1.5;
  }

  .lineup-section .lineup-card__button {
    margin-top: 18px;
  }

  .lineup-card__view-pill {
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 28px;
    padding: 0 12px;
    border: 1.5px solid var(--c-ink);
    border-radius: var(--r-pill);
    background: var(--c-paper);
    color: var(--c-ink);
    font-family: Fredoka, system-ui, sans-serif;
    font-size: .72rem;
    font-weight: 700;
    line-height: 1;
    box-shadow: 2px 2px 0 rgba(58, 51, 44, .18);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }

  .lineup-card__media:hover .lineup-card__view-pill {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 rgba(58, 51, 44, .24);
  }

  @media (max-width: 1120px) {
    .lineup-section .lineup-grid {
      grid-template-columns: repeat(2, minmax(280px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .lineup-section .lineup-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

