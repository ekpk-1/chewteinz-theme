<div class="fixed bottom-8 right-8 z-40" id="floating-cart-btn">
  <button
    type="button"
    onclick="window.cartDrawer.open()"
    class="relative p-4 bg-chewteinz-yellow rounded-full shadow-2xl hover:scale-110 transition-transform"
    aria-label="Open cart"
    tabindex="0"
  >
    {% render 'icon', icon: 'shopping-cart', size: 24 %}
    <span class="cart-count-badge absolute -top-1 -right-1 bg-chewteinz-pink text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center animate-bounce {% if cart.item_count == 0 %}hidden{% endif %}">
      {{ cart.item_count }}
    </span>
  </button>
</div>

<div class="fixed inset-0 z-[70] overflow-hidden hidden" id="cart-drawer">
  <div class="absolute inset-0 bg-black/50" onclick="window.cartDrawer.close()"></div>

  <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300" id="cart-drawer-panel">
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <h2 class="text-2xl font-display font-bold text-gray-800">
        Your Cart (<span id="cart-drawer-count">{{ cart.item_count }}</span>)
      </h2>
      <button
        type="button"
        onclick="window.cartDrawer.close()"
        class="p-2 hover:bg-gray-100 rounded-full transition-colors"
        aria-label="Close cart"
        tabindex="0"
      >
        {% render 'icon', icon: 'x', size: 24 %}
      </button>
    </div>

    <div class="flex-1 overflow-y-auto p-6" id="cart-drawer-items">
      {% if cart.item_count == 0 %}
        <div class="text-center py-12" id="cart-empty-state">
          <div class="text-6xl mb-4">🛒</div>
          <p class="text-lg text-gray-600 font-body">Your cart is empty</p>
          <p class="text-sm text-gray-500 mt-2">Add some delicious protein treats!</p>
        </div>
      {% else %}
        <div class="space-y-4" id="cart-items-list">
          {% for item in cart.items %}
            <div class="flex gap-4 bg-gray-50 rounded-2xl p-4 hover:bg-gray-100 transition-colors" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
              <div class="w-20 h-20 flex-shrink-0 bg-gradient-to-br from-chewteinz-yellow to-chewteinz-pink rounded-xl overflow-hidden">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 160, height: 160 }}" alt="{{ item.title | escape }}" class="w-full h-full object-cover" width="160" height="160" loading="lazy">
                {% else %}
                  <div class="w-full h-full flex items-center justify-center text-2xl">🍬</div>
                {% endif %}
              </div>

              <div class="flex-1 min-w-0">
                <h3 class="font-display font-semibold text-gray-800 truncate">{{ item.product.title }}</h3>
                <p class="text-sm text-gray-600 mb-2">{{ item.price | money }} each</p>
                <div class="flex items-center gap-2">
                  <button type="button" onclick="window.cartDrawer.updateQuantity('{{ item.key }}', {{ item.quantity | minus: 1 }})" class="p-1 bg-white rounded-full hover:bg-gray-200 transition-colors" aria-label="Decrease quantity">
                    {% render 'icon', icon: 'minus', size: 14 %}
                  </button>
                  <span class="w-8 text-center font-semibold">{{ item.quantity }}</span>
                  <button type="button" onclick="window.cartDrawer.updateQuantity('{{ item.key }}', {{ item.quantity | plus: 1 }})" class="p-1 bg-white rounded-full hover:bg-gray-200 transition-colors" aria-label="Increase quantity">
                    {% render 'icon', icon: 'plus', size: 14 %}
                  </button>
                </div>
              </div>

              <div class="flex flex-col items-end justify-between">
                <button type="button" onclick="window.cartDrawer.removeItem('{{ item.key }}')" class="p-2 text-red-500 hover:bg-red-50 rounded-full transition-colors" aria-label="Remove item">
                  {% render 'icon', icon: 'trash-2', size: 18 %}
                </button>
                <p class="font-display font-bold text-gray-800">{{ item.line_price | money }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="border-t border-gray-200 p-6 space-y-4 {% if cart.item_count == 0 %}hidden{% endif %}" id="cart-drawer-footer">
      <div class="flex items-center justify-between text-lg">
        <span class="font-display font-semibold text-gray-800">Total:</span>
        <span class="font-display font-bold text-2xl text-gray-800" id="cart-drawer-total">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="block w-full py-4 rounded-full font-display font-bold text-lg transition-transform bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink text-white hover:scale-105 text-center">
        Checkout
      </a>
      <p class="text-xs text-gray-500 text-center">You'll be redirected to secure checkout</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
