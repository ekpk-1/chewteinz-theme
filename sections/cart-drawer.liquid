{%- comment -%}
  Cart drawer chrome — matches the redesigned visual language while preserving
  the public DOM contract used by assets/cart.js:
    #cart-drawer, #cart-drawer-panel, #cart-drawer-count, #cart-drawer-total,
    #cart-drawer-footer, #cart-drawer-items, .cart-count-badge
{%- endcomment -%}

<div class="fixed inset-0 z-[70] overflow-hidden hidden" id="cart-drawer">
  <div class="absolute inset-0 bg-chewteinz-ink/45" onclick="window.cartDrawer.close()"></div>

  <aside
    class="absolute right-0 top-0 h-full w-full max-w-md bg-chewteinz-cream shadow-[0_24px_48px_-12px_rgba(26,22,20,0.3)] flex flex-col transform translate-x-full transition-transform duration-300"
    style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
    id="cart-drawer-panel"
    aria-label="Cart">
    <header class="flex items-center justify-between px-6 py-5 border-b border-chewteinz-ink/10">
      <h2 class="font-display font-bold text-xl text-chewteinz-ink">
        Your bag (<span id="cart-drawer-count">{{ cart.item_count }}</span>)
      </h2>
      <button
        type="button"
        onclick="window.cartDrawer.close()"
        class="icon-btn"
        aria-label="Close cart">
        <svg class="w-[22px] h-[22px]"><use href="#i-x"/></svg>
      </button>
    </header>

    <div class="flex-1 overflow-y-auto p-6" id="cart-drawer-items">
      {%- if cart.item_count == 0 -%}
        <div class="text-center py-12" id="cart-empty-state">
          <div class="text-5xl mb-4" aria-hidden="true">🛒</div>
          <p class="text-lg font-display font-semibold text-chewteinz-ink">Your bag is empty</p>
          <p class="text-sm text-chewteinz-ink-soft mt-2">Add a flavour to see the drawer fill.</p>
        </div>
      {%- else -%}
        <div class="space-y-4" id="cart-items-list">
          {%- for item in cart.items -%}
            <div class="flex gap-4 bg-white rounded-2xl p-4 border border-chewteinz-ink/10" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
              <div class="w-20 h-20 flex-shrink-0 bg-chewteinz-cream-2 rounded-xl overflow-hidden grid place-items-center">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 160, height: 160 }}" alt="{{ item.title | escape }}" class="w-full h-full object-cover" width="160" height="160" loading="lazy">
                {%- else -%}
                  <div class="text-2xl">🍬</div>
                {%- endif -%}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-display font-semibold text-chewteinz-ink truncate">{{ item.product.title }}</h3>
                <p class="text-sm text-chewteinz-ink-soft mb-2">{{ item.price | money }} each</p>
                <div class="flex items-center gap-2">
                  <button type="button" onclick="window.cartDrawer.updateQuantity('{{ item.key }}', {{ item.quantity | minus: 1 }})" class="w-7 h-7 grid place-items-center rounded-full border border-chewteinz-ink/20 hover:border-chewteinz-ink transition-colors" aria-label="Decrease quantity">
                    <svg class="w-3 h-3"><use href="#i-minus"/></svg>
                  </button>
                  <span class="w-8 text-center font-semibold tabular-nums">{{ item.quantity }}</span>
                  <button type="button" onclick="window.cartDrawer.updateQuantity('{{ item.key }}', {{ item.quantity | plus: 1 }})" class="w-7 h-7 grid place-items-center rounded-full border border-chewteinz-ink/20 hover:border-chewteinz-ink transition-colors" aria-label="Increase quantity">
                    <svg class="w-3 h-3"><use href="#i-plus"/></svg>
                  </button>
                </div>
              </div>
              <div class="flex flex-col items-end justify-between">
                <button type="button" onclick="window.cartDrawer.removeItem('{{ item.key }}')" class="text-chewteinz-ink-soft hover:text-chewteinz-ink transition-colors p-1" aria-label="Remove item">
                  <svg class="w-4 h-4"><use href="#i-x"/></svg>
                </button>
                <p class="font-display font-bold text-chewteinz-ink">{{ item.line_price | money }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <footer class="border-t border-chewteinz-ink/10 p-6 space-y-3 {% if cart.item_count == 0 %}hidden{% endif %}" id="cart-drawer-footer">
      <div class="flex items-center justify-between">
        <span class="font-display font-semibold text-chewteinz-ink">Subtotal</span>
        <span class="font-display font-bold text-2xl text-chewteinz-ink" id="cart-drawer-total">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="btn btn--gradient btn--lg btn--block">Checkout</a>
      <p class="text-xs text-chewteinz-ink-soft text-center">You'll be redirected to secure checkout.</p>
    </footer>
  </aside>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
