{% liquid
  assign policy_type = section.settings.policy_type
  assign policy_title = page.title
  assign last_updated = 'now' | date: '%B %d, %Y'

  if policy_type == 'privacy_policy'
    assign policy_title = 'Privacy Policy'
  elsif policy_type == 'refund_policy'
    assign policy_title = 'Refund & Returns'
  elsif policy_type == 'shipping_policy'
    assign policy_title = 'Shipping Policy'
  elsif policy_type == 'terms_of_service'
    assign policy_title = 'Terms of Service'
  endif
%}

<div class="min-h-screen pt-32 pb-20 bg-gradient-to-b from-chewteinz-blue/20 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h1 class="text-6xl md:text-7xl font-display font-bold mb-6 bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink bg-clip-text text-transparent">
        {{ policy_title }}
      </h1>
      {% if section.settings.page_subtitle != blank %}
        <p class="text-2xl text-gray-600 font-body">
          {{ section.settings.page_subtitle }}
        </p>
      {% endif %}
      {% if policy_type == 'shipping_policy' or policy_type == 'terms_of_service' %}
        <p class="text-sm text-gray-500 font-body mt-4">
          Last updated: {{ last_updated }}
        </p>
      {% endif %}
    </div>

    <div class="bg-white rounded-3xl p-8 md:p-12 shadow-lg space-y-12">

      {% if policy_type == 'privacy_policy' %}

        <div class="pt-4">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-purple to-chewteinz-pink rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">How We Use Your Information</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">We use your information to:</p>
          <ul class="space-y-2 ml-6 mb-6" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Respond to enquiries</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Fulfil and deliver orders</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Process payments</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Improve customer experience</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Detect and prevent fraud</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Send order updates or account notifications</span>
            </li>
          </ul>
          <div class="bg-chewteinz-blue/20 border-2 border-chewteinz-blue rounded-xl p-4">
            <p class="text-gray-800 font-body font-semibold">We do not sell or rent your data.</p>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-blue to-chewteinz-purple rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><ellipse
                  cx="12"
                  cy="5"
                  rx="9"
                  ry="3" /><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Where Your Data Is Stored</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">Your data may be stored across:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Shopify</span>
              </span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Make.com</span>
              </span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Klaviyo</span>
              </span>
            </li>
          </ul>
          <p class="text-gray-700 font-body leading-relaxed">All platforms comply with international security standards.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-pink to-chewteinz-purple rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><circle
                  cx="18"
                  cy="5"
                  r="3" /><circle
                  cx="6"
                  cy="12"
                  r="3" /><circle
                  cx="18"
                  cy="19"
                  r="3" /><line
                  x1="8.59"
                  y1="13.51"
                  x2="15.42"
                  y2="17.49" /><line
                  x1="15.41"
                  y1="6.51"
                  x2="8.59"
                  y2="10.49" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Sharing Your Personal Information</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">We share your information only when necessary:</p>
          <ul class="space-y-2 ml-6 mb-6" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Shopify</span>
                for order processing</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Shipping carriers</span>
                (e.g., StarTrack) to deliver orders</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Klaviyo</span>
                for email marketing and
                <span class="font-semibold">Make.com</span>
                for contact form processing</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>
                <span class="font-semibold">Legal authorities</span>
                if required by law</span>
            </li>
          </ul>
          <div class="bg-chewteinz-yellow/20 border-2 border-chewteinz-yellow rounded-xl p-4">
            <p class="text-gray-800 font-body font-semibold">We do not share your information with advertisers or unrelated third parties.</p>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-yellow to-chewteinz-orange rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5" /><path d="M8.5 8.5v.01" /><path d="M16 15.5v.01" /><path d="M12 12v.01" /><path d="M11 17v.01" /><path d="M7 14v.01" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Cookies &amp; Tracking</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">Shopify uses cookies for:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Analytics</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Cart functionality</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Checkout security</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Personalized browsing</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body leading-relaxed">You may disable cookies in your browser, but certain features may not function.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-purple to-chewteinz-blue rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Data Access &amp; Deletion Requests</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">You may request:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>A copy of your stored personal data</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Correction of incorrect data</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Deletion (where legally allowed)</span>
            </li>
          </ul>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-pink to-chewteinz-purple rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><rect
                  x="3"
                  y="11"
                  width="18"
                  height="11"
                  rx="2"
                  ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Security</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">We follow industry-standard practices to protect personal information from loss, misuse, and unauthorized access.</p>
          <div class="bg-orange-50 border-2 border-orange-200 rounded-xl p-4">
            <p class="text-gray-800 font-body">However, no system is 100% secure, and we cannot guarantee absolute protection.</p>
          </div>
        </div>

        <div class="bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink rounded-xl p-8 text-center text-white mt-8">
          <h3 class="text-2xl font-display font-bold mb-4">Questions About Privacy?</h3>
          <p class="text-lg font-body mb-6">We&rsquo;re committed to protecting your personal information and being transparent about our practices.</p>
          <a
            href="/pages/contact"
            class="inline-block bg-white text-chewteinz-purple px-8 py-3 rounded-full font-display font-bold text-lg hover:scale-105 transition-transform"
            tabindex="0"
            aria-label="Contact us about privacy">Contact Us</a>
        </div>

      {% elsif policy_type == 'refund_policy' %}

        <div>
          <p class="text-lg text-gray-700 font-body leading-relaxed">At ChewTeinz, we want you to be satisfied with your purchase. This Refund &amp; Returns Policy outlines your rights under the Australian Consumer Law (ACL) and our store&rsquo;s specific return procedures.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-purple to-chewteinz-pink rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Australian Consumer Law &mdash; Your Rights</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">Under ACL, customers are entitled to a replacement, refund or repair when an item is:</p>
          <ul class="space-y-2 ml-6" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Faulty or defective</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Unsafe</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Significantly different from the description</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Not fit for purpose</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body mt-4 font-semibold">These rights cannot be excluded.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-blue to-chewteinz-purple rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><line
                  x1="16.5"
                  y1="9.4"
                  x2="7.5"
                  y2="4.21" /><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /><polyline points="3.27 6.96 12 12.01 20.73 6.96" /><line
                  x1="12"
                  y1="22.08"
                  x2="12"
                  y2="12" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Change-of-Mind Returns</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">We accept change of mind returns if the following conditions are met:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>The product is unopened, unused, and in original packaging</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Returned within 14 days of receiving your order</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Return shipping costs are paid by the customer</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Customer must provide proof of purchase</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body leading-relaxed">Refunds for change of mind apply to product cost only. Shipping fees are non-refundable.</p>
          <div class="bg-chewteinz-yellow/20 border-2 border-chewteinz-yellow rounded-xl p-4 mt-4">
            <p class="text-gray-800 font-body font-semibold">Due to food safety laws, opened or used edible products cannot be returned unless the item is faulty.</p>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <h2 class="text-3xl font-display font-bold text-gray-800 mb-6">Faulty or Defective Items</h2>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">If your item arrives:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Damaged</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Faulty</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Incorrect</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Unsafe</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">You are entitled to a free replacement or full refund, including shipping.</p>
          <p class="text-gray-700 font-body mb-2 leading-relaxed">We may request:</p>
          <ul class="space-y-2 ml-6" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>A photo or video showing the fault</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>The batch number</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Order details</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body mt-4 leading-relaxed">This helps us investigate quality issues.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-pink to-chewteinz-purple rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">How to Lodge a Return</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">Please contact us through our
            <a href="/pages/contact" class="text-chewteinz-purple font-semibold hover:underline">Contact Us</a>
            form or email:</p>
          <p class="text-gray-700 font-body mb-2 leading-relaxed">Include:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Full name</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Order number</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Reason for return</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Evidence (photos if applicable)</span>
            </li>
          </ul>
          <p class="text-gray-700 font-body leading-relaxed">We will respond within 1&ndash;2 business days.</p>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <h2 class="text-3xl font-display font-bold text-gray-800 mb-6">Return Shipping</h2>
          <div class="space-y-3">
            <p class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2 font-bold">&rarr;</span>
              <span>
                <span class="font-semibold">For change-of-mind returns</span>
                &mdash; customer pays</span>
            </p>
            <p class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2 font-bold">&rarr;</span>
              <span>
