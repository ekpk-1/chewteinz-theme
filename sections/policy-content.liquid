                  x1="12"
                  y1="17"
                  x2="12.01"
                  y2="17" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Limitation of Liability</h2>
            </div>
          </div>
          <p class="text-gray-700 font-body mb-4 leading-relaxed">ChewTeinz is not liable for:</p>
          <ul class="space-y-2 ml-6 mb-4" style="list-style:none;">
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Losses from misuse of products</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Delays caused by the shipping carrier</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Data breaches on third-party platforms</span>
            </li>
            <li class="text-gray-700 font-body flex items-start">
              <span class="text-chewteinz-pink mr-2">&bull;</span>
              <span>Customer error during checkout</span>
            </li>
          </ul>
          <div class="bg-orange-50 border-2 border-orange-200 rounded-xl p-4">
            <p class="text-gray-800 font-body font-semibold">Our maximum liability is limited to the purchase price of the product.</p>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-chewteinz-purple to-chewteinz-pink rounded-full flex items-center justify-center flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            </div>
            <div>
              <h2 class="text-3xl font-display font-bold text-gray-800 mb-4">Contact Information</h2>
            </div>
          </div>
        </div>

        <div class="bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink rounded-xl p-8 text-center text-white mt-8">
          <h3 class="text-2xl font-display font-bold mb-4">Questions About Our Terms?</h3>
          <p class="text-lg font-body mb-6">We&rsquo;re here to help clarify anything you need to know.</p>
          <a
            href="/pages/contact"
            class="inline-block bg-white text-chewteinz-purple px-8 py-3 rounded-full font-display font-bold text-lg hover:scale-105 transition-transform"
            tabindex="0"
            aria-label="Contact us about our terms">Contact Us</a>
        </div>

      {% else %}

        <div class="policy-content max-w-none font-body text-gray-700 leading-relaxed">
          {{ page.content }}
        </div>
        <style>
          .policy-content h2 {
            font-family: "Fredoka"
            , system-ui
            , sans-serif;
            font-weight: 700;
            color: #1f2937;
            font-size: 1.875rem;
            margin-top: 2rem;
            margin-bottom: 1rem;
            padding-top: 2rem;
            border-top: 1px solid #e5e7eb;
          }
          .policy-content h3 {
            font-family: "Fredoka"
            , system-ui
            , sans-serif;
            font-weight: 700;
            color: #1f2937;
            font-size: 1.5rem;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
          }
          .policy-content p {
            margin-bottom: 1rem;
            line-height: 1.625;
          }
          .policy-content ul {
            list-style: disc;
            margin-left: 1.5rem;
            margin-bottom: 1rem;
          }
          .policy-content ol {
            list-style: decimal;
            margin-left: 1.5rem;
            margin-bottom: 1rem;
          }
          .policy-content ul li,
          .policy-content ol li {
            color: #374151;
            margin-bottom: 0.5rem;
          }
          .policy-content a {
            color: #C8A2F0;
            font-weight: 600;
          }
          .policy-content a:hover {
            text-decoration: underline;
          }
          .policy-content strong {
            font-weight: 600;
          }
        </style>
        <div class="bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink rounded-xl p-8 text-center text-white mt-12">
          <h3 class="text-2xl font-display font-bold mb-4">Need Help?</h3>
          <p class="text-lg font-body mb-6">Our team is here to assist you with any questions.</p>
          <a
            href="/pages/contact"
            class="inline-block bg-white text-chewteinz-purple px-8 py-3 rounded-full font-display font-bold text-lg hover:scale-105 transition-transform"
            tabindex="0"
            aria-label="Contact us for help">Contact Us</a>
        </div>

      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Policy Content",
    "settings": [
      {
        "type": "select",
        "id": "policy_type",
        "label": "Policy Type",
        "info": "Select which store policy to display. Falls back to page content if not set.",
        "default": "none",
        "options": [
          {
            "value": "none",
            "label": "Use Page Content"
          },
          {
            "value": "privacy_policy",
            "label": "Privacy Policy"
          },
          {
            "value": "refund_policy",
            "label": "Refund Policy"
          },
          {
            "value": "shipping_policy",
            "label": "Shipping Policy"
          }, {
            "value": "terms_of_service",
            "label": "Terms of Service"
          }
        ]
      }, {
        "type": "text",
        "id": "page_subtitle",
        "label": "Page Subtitle"
      }
    ]
  }
{% endschema %}