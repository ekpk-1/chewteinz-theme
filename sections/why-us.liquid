<section class="py-12 sm:py-16 md:py-20 bg-gradient-to-br from-chewteinz-blue to-chewteinz-purple">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-10 md:gap-12 items-center">
      <div class="relative">
        <img
          src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTAzp81qYdzGFpfVKBbR6Qy9iWxIh3krP4LwZS"
          alt=""
          class="w-16 h-16 sm:w-20 sm:h-20 md:w-28 md:h-28 opacity-20 absolute -top-8 -left-4 sm:-top-12 sm:-left-8 animate-float"
          style="transform: rotate(-20deg)"
          loading="lazy"
        >
        <img
          src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTAzp81qYdzGFpfVKBbR6Qy9iWxIh3krP4LwZS"
          alt=""
          class="w-16 h-16 sm:w-20 sm:h-20 md:w-28 md:h-28 opacity-20 absolute bottom-0 right-0 animate-float"
          style="animation-delay: 2s; transform: rotate(30deg)"
          loading="lazy"
        >
        <img
          src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTAzp81qYdzGFpfVKBbR6Qy9iWxIh3krP4LwZS"
          alt=""
          class="w-16 h-16 sm:w-20 sm:h-20 md:w-28 md:h-28 opacity-20 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-float"
          style="animation-delay: 4s; transform: translate(-50%, -50%) rotate(-45deg)"
          loading="lazy"
        >
        <div class="relative z-10 bg-white/20 backdrop-blur-sm rounded-3xl p-6 sm:p-8 md:p-12 text-center overflow-visible">
          <div class="overflow-visible">
            <img
              src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTTIMCUx8Hbgd0zAB7flMmysjRpa9VuUxc38CE"
              alt="ChewTeinz Product"
              class="w-full max-w-[300px] sm:max-w-[500px] md:max-w-[800px] h-auto mb-3 sm:mb-4 rounded-2xl mx-auto scale-[1.5] sm:scale-[1.75] md:scale-[2]"
            >
          </div>
          <p class="text-lg sm:text-xl md:text-2xl font-display font-bold text-white">
            Fitness Meets Fun
          </p>
        </div>
      </div>

      <div class="text-white">
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-4 sm:mb-5 md:mb-6 text-shadow">
          {{ section.settings.heading }}
        </h2>
        <p class="text-base sm:text-lg md:text-xl lg:text-2xl font-body leading-relaxed mb-4 sm:mb-5 md:mb-6">
          We've reimagined gummies into a light-hearted, protein-packed treat that fuels your day without the sugar crash. Bursting with bold fruity flavour, ChewTeinz are your go-to snack when you need something tasty, satisfying and better for you.
        </p>
        <p class="text-base sm:text-lg md:text-xl lg:text-2xl font-body leading-relaxed mb-6 sm:mb-7 md:mb-8">
          Whether it's post workout, mid-study or just when cravings hit, ChewTeinz let's you snack happy and guilt-free.
        </p>
        <div class="flex flex-wrap gap-3 sm:gap-4">
          <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 sm:px-6 sm:py-3 font-display font-semibold text-sm sm:text-base flex items-center gap-2">
            <span class="text-green-300 text-xl sm:text-2xl">●</span> Clean Ingredients
          </div>
          <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 sm:px-6 sm:py-3 font-display font-semibold text-sm sm:text-base flex items-center gap-2">
            <span class="text-yellow-300 text-xl sm:text-2xl">●</span> No Artificial Colors
          </div>
          <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 sm:px-6 sm:py-3 font-display font-semibold text-sm sm:text-base flex items-center gap-2">
            <span class="text-pink-300 text-xl sm:text-2xl">●</span> Gluten Free
          </div>
          <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 sm:px-6 sm:py-3 font-display font-semibold text-sm sm:text-base flex items-center gap-2">
            <span class="text-orange-300 text-xl sm:text-2xl">●</span> Made with Love
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We Make Fitness Taste Fun"
    }
  ]
}
{% endschema %}
