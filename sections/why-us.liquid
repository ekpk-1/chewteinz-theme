{%- liquid
  assign accent_word = section.settings.accent_word | default: 'taste fun'
  assign heading = section.settings.heading
  assign media_image = section.settings.media_image
-%}

<section class="ct-section why-section relative overflow-hidden" id="about">
  {% render 'floating-candy'
    , preset: 'why' %}

  <div class="ct-container why__inner">
    <div class="why__media reveal" data-delay="1">
      {%- if media_image != blank -%}
        <img
          src="{{ media_image | image_url: width: 800 }}"
          alt="{{ media_image.alt | default: shop.name }}"
          loading="lazy"
          width="{{ media_image.width }}"
          height="{{ media_image.height }}">
      {%- else -%}
        <img
          src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTTIMCUx8Hbgd0zAB7flMmysjRpa9VuUxc38CE"
          alt="{{ shop.name }} logo"
          width="800"
          height="800"
          loading="lazy">
      {%- endif -%}
    </div>

    <div class="why__copy reveal" data-delay="2">
      <h2>
        {%- if heading contains accent_word and accent_word != blank -%}
          {%- assign parts = heading | split: accent_word -%}
          {{ parts[0] }}<em>{{ accent_word }}</em>
          {{ parts[1] }}
        {%- else -%}
          {{ heading }}
        {%- endif -%}
      </h2>

      {%- if section.settings.body_1 != blank -%}
        <p>{{ section.settings.body_1 }}</p>
      {%- endif -%}
      {%- if section.settings.body_2 != blank -%}
        <p>{{ section.settings.body_2 }}</p>
      {%- endif -%}

      <div class="why__pills">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <span
              class="pill"
              style="--dot: {{ block.settings.dot_color }}"
              {{ block.shopify_attributes }}>
              <span class="dot"></span>
              {{ block.settings.label }}
            </span>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Fallback default pills when no blocks have been saved. {%- endcomment -%}
          <span class="pill" style="--dot: #3CC68A">
            <span class="dot"></span>
            Clean Ingredients</span>
          <span class="pill" style="--dot: #F5C400">
            <span class="dot"></span>
            No Artificial Colours</span>
          <span class="pill" style="--dot: #E66EB8">
            <span class="dot"></span>
            Gluten Free</span>
          <span class="pill" style="--dot: #E88A4D">
            <span class="dot"></span>
            Made with Love</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Why Us",
    "settings": [
      {
        "type": "image_picker",
        "id": "media_image",
        "label": "Media image"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "We make fitness taste fun."
      },
      {
        "type": "text",
        "id": "accent_word",
        "label": "Accent word/phrase",
        "info": "Words inside the heading rendered as the visual accent.",
        "default": "taste fun"
      },
      {
        "type": "textarea",
        "id": "body_1",
        "label": "Body paragraph 1",
        "default": "We've reimagined gummies into a light-hearted, protein-packed treat that fuels your day without the sugar crash. Bursting with bold fruity flavour, ChewTeinz are your go-to snack when you need something tasty, satisfying and better for you."
      }, {
        "type": "textarea",
        "id": "body_2",
        "label": "Body paragraph 2",
        "default": "Whether it's post-workout, mid-study, or just when cravings hit — ChewTeinz let you snack happy and guilt-free."
      }
    ],
    "blocks": [
      {
        "type": "pill",
        "name": "Trust pill",
        "settings": [
          {
            "type": "text",
            "id": "label",
            "label": "Label",
            "default": "Clean Ingredients"
          }, {
            "type": "color",
            "id": "dot_color",
            "label": "Dot colour",
            "default": "#3CC68A"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Why Us",
        "blocks": [
          {
            "type": "pill",
            "settings": {
              "label": "Clean Ingredients",
              "dot_color": "#3CC68A"
            }
          }, {
            "type": "pill",
            "settings": {
              "label": "No Artificial Colours",
              "dot_color": "#F5C400"
            }
          }, {
            "type": "pill",
            "settings": {
              "label": "Gluten Free",
              "dot_color": "#E66EB8"
            }
          }, {
            "type": "pill",
            "settings": {
              "label": "Made with Love",
              "dot_color": "#E88A4D"
            }
          }
        ]
      }
    ]
  }
{% endschema %}