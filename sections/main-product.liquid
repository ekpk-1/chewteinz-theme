{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign soft_color = section.settings.soft_color | default: '#F6E1C6'
  assign deep_color = section.settings.deep_color | default: '#A06E37'
  assign badge = section.settings.badge
  if badge == blank
    if product.available
      assign badge = section.settings.available_badge
    else
      assign badge = section.settings.sold_out_badge
    endif
  endif

  assign has_flavour_blocks = false
  for block in section.blocks
    if block.type == 'flavour'
      assign has_flavour_blocks = true
    endif
  endfor
-%}

<section class="ct-section product-main" data-ct-product-section data-currency="{{ cart.currency.iso_code | default: shop.currency }}" style="--product-soft: {{ soft_color }}; --product-deep: {{ deep_color }};">
  <div class="ct-container">
    <div class="product-main__nav">
      <a class="product-main__back" href="{{ routes.root_url }}#ct-shop">{{ section.settings.back_label }}</a>
      {%- if section.settings.show_product_jump and has_flavour_blocks -%}
        <label class="product-main__jump">
          <span>{{ section.settings.jump_label }}</span>
          <select data-ct-product-jump>
            <option value="{{ product.url }}" selected>{{ product.title }}</option>
            {%- for block in section.blocks -%}
              {%- if block.type == 'flavour' -%}
                {%- liquid
                  assign flavour_product = block.settings.product
                  assign flavour_title = block.settings.title
                  if flavour_title == blank and flavour_product != blank
                    assign flavour_title = flavour_product.title
                  endif

                  assign flavour_url = block.settings.link
                  if flavour_url == blank and flavour_product != blank
                    assign flavour_url = flavour_product.url
                  endif
                  if flavour_url == blank
                    assign flavour_url = '#ct-waitlist'
                  endif

                  assign flavour_badge = block.settings.badge
                -%}
                {%- if flavour_title != blank -%}
                  <option value="{{ flavour_url }}">{{ flavour_title }}{% if flavour_badge contains 'Coming soon' %} - soon{% endif %}</option>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </select>
        </label>
      {%- endif -%}
    </div>

    <div class="product-main__inner">
      <div class="product-main__gallery reveal" data-delay="1">
        <div class="product-main__media">
          {%- if badge != blank -%}
            <span class="product-main__badge">{{ badge }}</span>
          {%- endif -%}

          <img
            data-ct-product-main-image
            src="{{ 'bag-mango.png' | asset_url }}"
            alt="{{ product.title | escape }}"
            width="874"
            height="1184">
        </div>

        <div class="product-main__thumbs" aria-label="Product images">
          <button
            type="button"
            class="product-main__thumb is-active"
            data-ct-product-thumb
            data-image-src="{{ 'bag-mango.png' | asset_url }}"
            data-image-srcset=""
            data-image-alt="{{ product.title | escape }}"
            aria-label="Show {{ product.title | escape }} front">
            <img src="{{ 'bag-mango.png' | asset_url }}" alt="{{ product.title | escape }}" width="874" height="1184" loading="lazy">
          </button>
          <button
            type="button"
            class="product-main__thumb"
            data-ct-product-thumb
            data-image-src="{{ 'bag-mango.png' | asset_url }}"
            data-image-srcset=""
            data-image-alt="{{ product.title | escape }}"
            aria-label="Show {{ product.title | escape }} pack">
            <img src="{{ 'bag-mango.png' | asset_url }}" alt="{{ product.title | escape }}" width="874" height="1184" loading="lazy">
          </button>
          <button
            type="button"
            class="product-main__thumb"
            data-ct-product-thumb
            data-image-src="{{ 'mango-nutrition-info.png' | asset_url }}"
            data-image-srcset=""
            data-image-alt="{{ product.title | escape }} nutrition information"
            aria-label="Show {{ product.title | escape }} nutrition information">
            <img src="{{ 'mango-nutrition-info.png' | asset_url }}" alt="{{ product.title | escape }} nutrition information" width="1024" height="657" loading="lazy">
          </button>
        </div>
      </div>

      <div class="product-main__content reveal" data-delay="2">
        <h1>{{ product.title }}</h1>

        {%- if section.settings.show_rating -%}
          <div class="product-main__rating" aria-label="{{ section.settings.rating_label | escape }}">
            <span aria-hidden="true">★★★★★</span>
            <strong>{{ section.settings.rating_score }}</strong>
            <span>{{ section.settings.rating_text }}</span>
          </div>
        {%- endif -%}

        <div class="product-main__description">
          {%- if section.settings.description_override != blank -%}
            {{ section.settings.description_override }}
          {%- else -%}
            {{ product.description | strip_html | truncate: 210 }}
          {%- endif -%}
        </div>

        <div class="product-main__price">
          <span data-ct-product-price>{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s data-ct-product-compare-price>{{ current_variant.compare_at_price | money }}</s>
          {%- else -%}
            <s data-ct-product-compare-price hidden></s>
          {%- endif -%}
          {%- if section.settings.price_meta != blank -%}
            <small data-ct-product-price-meta>{{ section.settings.price_meta }}</small>
          {%- endif -%}
        </div>

        <div class="product-main__pills" aria-label="Product highlights">
          {%- if section.settings.pill_1 != blank -%}
            <span class="pill"><span class="dot" style="--dot: var(--c-pink)"></span>{{ section.settings.pill_1 }}</span>
          {%- endif -%}
          {%- if section.settings.pill_2 != blank -%}
            <span class="pill"><span class="dot" style="--dot: var(--c-green)"></span>{{ section.settings.pill_2 }}</span>
          {%- endif -%}
          {%- if section.settings.pill_3 != blank -%}
            <span class="pill"><span class="dot" style="--dot: var(--c-purple)"></span>{{ section.settings.pill_3 }}</span>
          {%- endif -%}
        </div>

        {%- form 'product', product, class: 'product-main__form', data-ct-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-ct-variant-input>

          <div class="product-main__selector-head">
            <label for="ProductSelect-{{ section.id }}">{{ section.settings.variant_label }}</label>
            {%- if section.settings.variant_badge != blank -%}
              <span>{{ section.settings.variant_badge }}</span>
            {%- endif -%}
          </div>

          <select id="ProductSelect-{{ section.id }}" class="product-main__select" data-ct-variant-select>
            {%- if section.settings.pack_3_variant_id != blank or section.settings.pack_10_variant_id != blank -%}
              <option
                value="{{ current_variant.id }}"
                data-price="{{ current_variant.price | money }}"
                data-price-cents="{{ current_variant.price }}"
                data-price-meta="AUD · 1 bag · 180g each · 20g protein/serve"
                data-compare-price="{% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}"
                data-available="{% if current_variant.available %}true{% else %}false{% endif %}"
                data-units="1"
                data-unit-price="{{ current_variant.price | money }}"
                data-save-amount="{{ 0 | money }}"
                data-save-percent="0"
                selected
                {% unless current_variant.available %}disabled{% endunless %}>
                {{ section.settings.pack_single_label }} · {{ current_variant.price | money }}
              </option>
              {%- if section.settings.pack_3_variant_id != blank -%}
                <option
                  value="{{ section.settings.pack_3_variant_id | strip }}"
                  data-price="{{ section.settings.pack_3_price_label }}"
                  data-price-cents="{{ section.settings.pack_3_price_cents | strip }}"
                  data-price-meta="AUD · 3 bags · 180g each · 20g protein/serve"
                  data-compare-price=""
                  data-available="true"
                  data-units="3"
                  data-unit-price="{{ section.settings.pack_3_unit_price_label }}"
                  data-save-amount="{{ section.settings.pack_3_save_amount_label }}"
                  data-save-percent="{{ section.settings.pack_3_save_percent }}"
                  {% if section.settings.pack_3_disabled %}disabled{% endif %}>
                  {{ section.settings.pack_3_label }} · {{ section.settings.pack_3_price_label }} - Save {{ section.settings.pack_3_save_percent }}% (most popular)
                </option>
              {%- endif -%}
              {%- if section.settings.pack_10_variant_id != blank -%}
                <option
                  value="{{ section.settings.pack_10_variant_id | strip }}"
                  data-price="{{ section.settings.pack_10_price_label }}"
                  data-price-cents="{{ section.settings.pack_10_price_cents | strip }}"
                  data-price-meta="AUD · 10 bags · 180g each · 20g protein/serve"
                  data-compare-price=""
                  data-available="true"
                  data-units="10"
                  data-unit-price="{{ section.settings.pack_10_unit_price_label }}"
                  data-save-amount="{{ section.settings.pack_10_save_amount_label }}"
                  data-save-percent="{{ section.settings.pack_10_save_percent }}"
                  {% if section.settings.pack_10_disabled %}disabled{% endif %}>
                  {{ section.settings.pack_10_label }} · {{ section.settings.pack_10_price_label }} - Save {{ section.settings.pack_10_save_percent }}% (best value)
                </option>
              {%- endif -%}
            {%- else -%}
              {%- for variant in product.variants -%}
              {%- liquid
                assign variant_units = 1
                assign variant_title = variant.title | downcase
                if variant_title contains '10'
                  assign variant_units = 10
                  assign pack_label = '10-Pack'
                  assign pack_tag = 'best value'
                elsif variant_title contains '3'
                  assign variant_units = 3
                  assign pack_label = '3-Pack'
                  assign pack_tag = 'most popular'
                else
                  assign pack_label = 'Single Bag'
                  assign pack_tag = ''
                endif

                assign variant_unit_price = variant.price | divided_by: variant_units
                assign base_total = product.variants.first.price | times: variant_units
                assign save_amount = base_total | minus: variant.price
                assign save_percent = 0
                if save_amount > 0 and base_total > 0
                  assign save_percent = save_amount | times: 100 | divided_by: base_total
                endif

                capture variant_price_meta
                  echo 'AUD · '
                  echo variant_units
                  if variant_units > 1
                    echo ' bags · 180g each · 20g protein/serve'
                  else
                    echo ' bag · 180g each · 20g protein/serve'
                  endif
                endcapture
              -%}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-price-cents="{{ variant.price }}"
                data-price-meta="{{ variant_price_meta | strip | escape }}"
                data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                data-available="{% if variant.available %}true{% else %}false{% endif %}"
                data-units="{{ variant_units }}"
                data-unit-price="{{ variant_unit_price | money }}"
                data-save-amount="{{ save_amount | money }}"
                data-save-percent="{{ save_percent }}"
                {% if variant == current_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}>
                {{ pack_label }} · {{ variant.price | money }}{% if save_percent > 0 %} - Save {{ save_percent }}%{% endif %}{% if pack_tag != blank %} ({{ pack_tag }}){% endif %}
              </option>
              {%- endfor -%}
            {%- endif -%}
          </select>

          <p class="product-main__variant-note" data-ct-variant-note data-default-note="{{ section.settings.variant_note | escape }}">{{ section.settings.variant_note }}</p>

          <div class="product-main__purchase">
            <div class="product-main__quantity" data-ct-quantity>
              <button type="button" data-ct-quantity-minus aria-label="Decrease quantity">-</button>
              <input type="number" name="quantity" value="1" min="1" data-ct-quantity-input aria-label="Quantity">
              <button type="button" data-ct-quantity-plus aria-label="Increase quantity">+</button>
            </div>

            <button
              type="submit"
              class="btn btn--lg btn--shadow product-main__add"
              data-ct-product-submit
              data-add-label="{{ section.settings.add_to_cart_label | escape }}"
              data-sold-out-label="{{ section.settings.sold_out_label | escape }}"
              {% unless current_variant.available %}disabled{% endunless %}>
              <span data-ct-product-submit-label>
                {%- if current_variant.available -%}
                  {{ section.settings.add_to_cart_label }} · {{ current_variant.price | money }} →
                {%- else -%}
                  {{ section.settings.sold_out_label }}
                {%- endif -%}
              </span>
            </button>
          </div>
        {%- endform -%}

        <div class="product-main__trust" aria-label="Purchase benefits">
          {%- if section.settings.trust_1 != blank -%}
            <span>{{ section.settings.trust_1 }}</span>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <span>{{ section.settings.trust_2 }}</span>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <span>{{ section.settings.trust_3 }}</span>
          {%- endif -%}
        </div>

        <div class="macro-strip" aria-label="Nutrition highlights">
          <div>
            <strong>{{ section.settings.macro_1_value }}</strong>
            <span>{{ section.settings.macro_1_label }}</span>
          </div>
          <div>
            <strong>{{ section.settings.macro_2_value }}</strong>
            <span>{{ section.settings.macro_2_label }}</span>
          </div>
          <div>
            <strong>{{ section.settings.macro_3_value }}</strong>
            <span>{{ section.settings.macro_3_label }}</span>
          </div>
          <div>
            <strong>{{ section.settings.macro_4_value }}</strong>
            <span>{{ section.settings.macro_4_label }}</span>
          </div>
        </div>

        <div class="product-main__info-grid">
          <article>
            <h2>{{ section.settings.info_1_title }}</h2>
            <p>{{ section.settings.info_1_text }}</p>
            {%- if section.settings.show_nutrition_link -%}
              <button type="button" onclick="window.modals && window.modals.openNutrition('{{ product.title | escape }}')">{{ section.settings.nutrition_link_label }}</button>
            {%- endif -%}
          </article>
          <article>
            <h2>{{ section.settings.info_2_title }}</h2>
            <p>{{ section.settings.info_2_text }}</p>
          </article>
        </div>
      </div>
    </div>

      {%- assign has_reviews = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          {%- assign has_reviews = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_reviews -%}
        <section class="product-main__reviews" aria-labelledby="ProductReviews-{{ section.id }}">
          <div class="product-main__reviews-head">
            <h2 id="ProductReviews-{{ section.id }}">{{ section.settings.reviews_heading }}</h2>
            <div>
              <span aria-hidden="true">★★★★★</span>
              <strong>{{ section.settings.rating_score }} · {{ section.settings.rating_text }}</strong>
            </div>
          </div>
          <div class="product-main__reviews-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'review' -%}
                {%- assign review_stars = '★★★★★' | slice: 0, block.settings.stars -%}
                <article class="product-main__review" {{ block.shopify_attributes }}>
                  <div class="product-main__review-head">
                    <span>{{ block.settings.name | slice: 0, 1 }}</span>
                    <div>
                      <strong>{{ block.settings.name }}</strong>
                      <em>{{ section.settings.verified_label }}</em>
                    </div>
                    <small>{{ block.settings.date }}</small>
                  </div>
                  <div class="product-main__review-stars" aria-label="{{ block.settings.stars }} out of 5 stars">{{ review_stars }}</div>
                  <h3>{{ block.settings.title }}</h3>
                  <p>{{ block.settings.body }}</p>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

      {%- if section.settings.show_related and has_flavour_blocks -%}
        <section class="product-main__related" aria-labelledby="ProductRelated-{{ section.id }}">
          <h2 id="ProductRelated-{{ section.id }}">{{ section.settings.related_heading }}</h2>
          <div class="product-main__related-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'flavour' -%}
                {%- liquid
                  assign flavour_product = block.settings.product
                  assign flavour_title = block.settings.title
                  if flavour_title == blank and flavour_product != blank
                    assign flavour_title = flavour_product.title
                  endif

                  assign flavour_url = block.settings.link
                  if flavour_url == blank and flavour_product != blank
                    assign flavour_url = flavour_product.url
                  endif
                  if flavour_url == blank
                    assign flavour_url = '#ct-waitlist'
                  endif

                  assign flavour_image = block.settings.image
                  if flavour_image == blank and flavour_product != blank
                    assign flavour_image = flavour_product.featured_image
                  endif

                  assign flavour_badge = block.settings.badge
                  if flavour_badge == blank
                    if flavour_product != blank and flavour_product.available
                      assign flavour_badge = flavour_product.price | money
                    else
                      assign flavour_badge = section.settings.related_coming_soon_label
                    endif
                  endif

                  assign fallback_asset = blank
                  assign flavour_title_downcase = flavour_title | downcase
                  if flavour_title_downcase contains 'watermelon'
                    assign fallback_asset = 'bag-watermelon.png'
                  elsif flavour_title_downcase contains 'blueberry'
                    assign fallback_asset = 'bag-blueberry.png'
                  elsif flavour_title_downcase contains 'travel'
                    assign fallback_asset = 'bag-mango-travel.png'
                  endif
                -%}
                {%- if flavour_title != blank -%}
                  <a class="product-main__related-card" href="{{ flavour_url }}" style="--flavour-soft: {{ block.settings.soft_color }}; --flavour-deep: {{ block.settings.deep_color }};" {{ block.shopify_attributes }}>
                    <div>
                      {%- if flavour_image != blank -%}
                        <img
                          src="{{ flavour_image | image_url: width: 420 }}"
                          alt="{{ flavour_image.alt | default: flavour_title | escape }}"
                          width="{{ flavour_image.width }}"
                          height="{{ flavour_image.height }}"
                          loading="lazy">
                      {%- elsif fallback_asset != blank -%}
                        <img
                          src="{{ fallback_asset | asset_url }}"
                          alt="{{ flavour_title | escape }}"
                          width="874"
                          height="1184"
                          loading="lazy">
                      {%- else -%}
                        <span>{{ flavour_title | slice: 0, 1 }}</span>
                      {%- endif -%}
                    </div>
                    <strong>{{ flavour_title }}</strong>
                    <small>{{ flavour_badge }}</small>
                    <em>{{ section.settings.related_link_label }}</em>
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-main {
    padding-block: clamp(var(--s-10), 6vw, var(--s-20));
    background: var(--c-cream);
  }

  .product-main__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    flex-wrap: wrap;
    margin-bottom: var(--s-6);
  }

  .product-main__back,
  .product-main__jump select {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    border: 1.5px solid var(--c-ink);
    border-radius: var(--r-pill);
    background: var(--c-paper);
    color: var(--c-ink);
    font-weight: 800;
  }

  .product-main__back {
    gap: var(--s-2);
    padding: 0 1.125rem;
  }

  .product-main__back:before {
    content: "\2190";
  }

  .product-main__jump {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    color: var(--c-ink-soft);
    font-size: .82rem;
    font-weight: 800;
  }

  .product-main__jump select {
    padding: 0 1rem;
    outline: none;
  }

  .product-main__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 52px;
    align-items: start;
  }

  .product-main__gallery {
    position: relative;
  }

  .product-main__media {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1;
    padding: 24px;
    border: 1.5px solid var(--c-ink);
    border-radius: 26px;
    background: var(--flavour-soft, var(--product-soft));
    box-shadow: 6px 6px 0 var(--c-ink);
    overflow: hidden;
  }

  .product-main__media img {
    width: auto;
    height: auto;
    max-width: 88%;
    max-height: 88%;
    object-fit: contain;
    filter: drop-shadow(0 20px 26px rgba(58, 51, 44, .24));
  }

  .product-main__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    padding: .3125rem .75rem;
    border: 1.5px solid var(--c-ink);
    border-radius: var(--r-pill);
    background: var(--product-deep);
    color: var(--c-paper);
    font-family: Fredoka, system-ui, sans-serif;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .04em;
  }

  .product-main__placeholder {
    display: grid;
    place-items: center;
    width: 60%;
    aspect-ratio: 1;
    border-radius: 28px;
    background: var(--c-paper);
    color: rgba(58, 51, 44, .2);
    font-family: Fredoka, system-ui, sans-serif;
    font-size: clamp(6rem, 16vw, 12rem);
    font-weight: 700;
  }

  .product-main__thumbs {
    display: flex;
    gap: var(--s-3);
    margin-top: var(--s-4);
  }

  .product-main__thumb {
    width: 74px;
    height: 74px;
    display: grid;
    place-items: center;
    padding: 6px;
    border: 2px solid rgba(58,51,44,.2);
    border-radius: 14px;
    background: var(--c-paper);
    overflow: hidden;
    transition: border-color var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
  }

  .product-main__thumb:hover,
  .product-main__thumb.is-active {
    border-color: var(--c-ink);
    transform: translateY(-1px);
  }

  .product-main__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-main__content h1 {
    font-size: clamp(2.35rem, 5vw, 4rem);
  }

  .product-main__rating {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: .45rem;
    margin-top: var(--s-3);
    color: var(--c-ink-soft);
    font-size: .875rem;
  }

  .product-main__rating span:first-child {
    color: var(--c-orange);
    letter-spacing: .08em;
  }

  .product-main__description {
    margin-top: var(--s-4);
    color: var(--c-ink-soft);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 62ch;
  }

  .product-main__price {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-3);
    margin-top: var(--s-5);
    font-family: Fredoka, system-ui, sans-serif;
    font-weight: 700;
  }

  .product-main__price span {
    font-size: 2.2rem;
  }

  .product-main__price s {
    color: var(--c-ink-mute);
    font-size: 1.15rem;
  }

  .product-main__price small {
    color: var(--c-ink-mute);
    font-family: Nunito, system-ui, sans-serif;
    font-size: .875rem;
    font-weight: 700;
  }

  .product-main__pills,
  .product-main__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-4);
  }

  .product-main__form {
    margin-top: var(--s-5);
  }

  .product-main__selector-head {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-2);
  }

  .product-main__selector-head label {
