{%- liquid
  assign accent_word = section.settings.accent_word | default: 'daily'
  assign heading = section.settings.heading
-%}

<section class="ct-section social-section" id="social">
  <div class="ct-container">
    <div class="social__head">
      <h2>
        {%- if heading contains accent_word and accent_word != blank -%}
          {%- assign parts = heading | split: accent_word -%}
          {{ parts[0] }}<em>{{ accent_word }}</em>{{ parts[1] }}
        {%- else -%}
          {{ heading }}
        {%- endif -%}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="mt-3 text-chewteinz-ink-soft">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="social__grid">
      {%- for block in section.blocks -%}
        {%- assign img_attr = block.settings.image -%}
        {%- assign url_attr = block.settings.image_url -%}
        {%- if block.settings.link != blank -%}
          <a class="social__tile" href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer" aria-label="Social post {{ forloop.index }}" {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="social__tile" {{ block.shopify_attributes }}>
        {%- endif -%}

          {%- if img_attr != blank -%}
            <img
              src="{{ img_attr | image_url: width: 600 }}"
              alt=""
              loading="lazy"
              width="600"
              height="600">
          {%- elsif url_attr != blank -%}
            <img
              src="{% if url_attr contains '://' %}{{ url_attr }}{% else %}{{ url_attr | asset_url }}{% endif %}"
              alt=""
              loading="lazy"
              width="600"
              height="600">
          {%- else -%}
            <div class="w-full h-full bg-gradient-to-br {{ block.settings.gradient | default: 'from-pink-400 to-purple-500' }} grid place-items-center">
              <img
                src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTAzp81qYdzGFpfVKBbR6Qy9iWxIh3krP4LwZS"
                alt=""
                class="w-1/3 opacity-40"
                loading="lazy">
            </div>
          {%- endif -%}

          <span class="ig" aria-hidden="true">
            <svg class="w-[22px] h-[22px]"><use href="#i-instagram"/></svg>
          </span>

        {%- if block.settings.link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-3 sm:gap-4 mt-10 sm:mt-12">
      <a
        href="{{ section.settings.instagram_url }}"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--gradient btn--lg w-full sm:w-auto">
        <svg class="w-[18px] h-[18px]" aria-hidden="true"><use href="#i-instagram"/></svg>
        Follow on Instagram
      </a>
      <a
        href="{{ section.settings.facebook_url }}"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--ghost btn--lg w-full sm:w-auto">
        <svg class="w-[18px] h-[18px]" aria-hidden="true"><use href="#i-facebook"/></svg>
        Follow on Facebook
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sweet gains, daily."
    },
    {
      "type": "text",
      "id": "accent_word",
      "label": "Accent word",
      "info": "Word inside the heading rendered as the visual accent.",
      "default": "daily"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tag @chewteinz to be featured."
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/chewteinz"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL",
      "default": "https://www.facebook.com/profile.php?id=61574701214256"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Social Image",
      "settings": [
        { "type": "image_picker", "id": "image",     "label": "Image" },
        { "type": "text",         "id": "image_url", "label": "External Image URL" },
        { "type": "url",          "id": "link",      "label": "Link" },
        { "type": "text",         "id": "gradient",  "label": "Fallback Gradient", "default": "from-pink-400 to-purple-500" }
      ]
    },
    {
      "type": "video",
      "name": "UGC Video",
      "settings": [
        { "type": "image_picker", "id": "image",     "label": "Image" },
        { "type": "text",         "id": "image_url", "label": "External Image URL" },
        { "type": "url",          "id": "link",      "label": "Instagram Reel Link" },
        { "type": "text",         "id": "gradient",  "label": "Fallback Gradient", "default": "from-purple-400 to-pink-500" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Feed",
      "blocks": [
        { "type": "image", "settings": { "image_url": "Followusimg1.png", "link": "https://www.instagram.com/reel/DU2e5yFDVho/", "gradient": "from-pink-400 to-purple-500" } },
        { "type": "image", "settings": { "image_url": "https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTBF56nDQl3oAhbDIGrSJNv7YtpkE86aigXRs4", "link": "https://www.instagram.com/p/DTj_8ZDk4Vc/", "gradient": "from-blue-400 to-cyan-500" } },
        { "type": "image", "settings": { "image_url": "https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsT6lm0dGSIb5XrW1u874y3wMHZYlzOSfjB2CAc", "link": "https://www.instagram.com/p/DTmfpSzE-S2/", "gradient": "from-red-400 to-pink-400" } },
        { "type": "image", "settings": { "image_url": "", "link": "https://www.instagram.com/p/DU4vuaKGT4B/", "gradient": "from-yellow-400 to-orange-500" } },
        { "type": "video", "settings": { "gradient": "from-green-400 to-lime-500" } },
        { "type": "video", "settings": { "gradient": "from-purple-400 to-pink-500" } }
      ]
    }
  ]
}
{% endschema %}
