<section class="ct-section benefits-section">
  <div class="ct-container">
    <div class="benefits__head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.subheading != blank -%}
        <p class="text-chewteinz-ink-soft max-w-[36ch] leading-relaxed">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      {%- for block in section.blocks -%}
        {%- assign accent = block.settings.accent | default: 'yellow' -%}
        {%- assign icon_key = block.settings.icon_key -%}
        {%- assign idx = forloop.index -%}
        {%- assign idx_padded = idx | prepend: '0' | slice: -2, 2 -%}

        <article
          class="card card--cream card--sticker benefit reveal"
          data-accent="{{ accent }}"
          data-delay="{{ idx }}"
          {{ block.shopify_attributes }}>
          <span class="numeral benefit__num">{{ idx_padded }}</span>
          <span class="benefit__icon" aria-hidden="true">
            {%- if icon_key != blank and icon_key != 'none' -%}
              <svg class="w-7 h-7"><use href="#i-{{ icon_key }}" /></svg>
            {%- elsif block.settings.icon_char != blank -%}
              <span class="font-display font-bold text-2xl">{{ block.settings.icon_char }}</span>
            {%- else -%}
              <svg class="w-7 h-7"><use href="#i-sparkles" /></svg>
            {%- endif -%}
          </span>
          <h3 class="benefit__title">{{ block.settings.title }}</h3>
          <p class="benefit__desc">{{ block.settings.description }}</p>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="flex justify-center mt-10 sm:mt-14">
        <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--gradient btn--lg">
          {{ section.settings.button_label }}
          <span class="btn__arrow">
            <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
          </span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
  {
    "name": "Benefits",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Why You'll Love Us"
      }, {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
        "default": "We reverse-engineered everything you hate about protein snacks — the chalky texture, the boring flavours, the crash — and made it taste like the candy aisle."
      }, {
        "type": "text",
        "id": "button_label",
        "label": "Button Label"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],
    "blocks": [
      {
        "type": "benefit",
        "name": "Benefit Card",
        "settings": [
          {
            "type": "select",
            "id": "icon_key",
            "label": "Icon",
            "default": "protein",
            "options": [
              {
                "value": "protein",
                "label": "Protein"
              },
              {
                "value": "droplet",
                "label": "Droplet"
              },
              {
                "value": "candy",
                "label": "Candy"
              },
              {
                "value": "refresh",
                "label": "Refresh"
              }, {
                "value": "leaf",
                "label": "Leaf"
              }, {
                "value": "zap",
                "label": "Zap"
              }, {
                "value": "heart",
                "label": "Heart"
              }, {
                "value": "shield",
                "label": "Shield"
              }, {
                "value": "truck",
                "label": "Truck"
              }, {
                "value": "star",
                "label": "Star"
              }, {
                "value": "sparkles",
                "label": "Sparkles"
              }, {
                "value": "none",
                "label": "None (use legacy character)"
              }
            ]
          },
          {
            "type": "select",
            "id": "accent",
            "label": "Accent colour",
            "default": "yellow",
            "options": [
              {
                "value": "yellow",
                "label": "Yellow"
              },
              {
                "value": "blue",
                "label": "Blue"
              },
              {
                "value": "pink",
                "label": "Pink"
              },
              {
                "value": "purple",
                "label": "Purple"
              }, {
                "value": "orange",
                "label": "Orange"
              }
            ]
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "High in Protein"
          },
          {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "20g of plant-based pea and rice protein per pack. Real strength fuel, in gummy form."
          }, {
            "type": "text",
            "id": "icon_char",
            "label": "Legacy icon character",
            "info": "Used as fallback if Icon is set to None.",
            "default": "⬢"
          }, {
            "type": "text",
            "id": "gradient",
            "label": "(legacy) Gradient classes",
            "info": "No longer used; kept for back-compat with saved settings."
          }, {
            "type": "text",
            "id": "icon_color",
            "label": "(legacy) Icon colour class",
            "info": "No longer used; kept for back-compat with saved settings."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Benefits",
        "blocks": [
          {
            "type": "benefit",
            "settings": {
              "icon_key": "protein",
              "accent": "blue",
              "title": "High in Protein",
              "description": "20g of plant-based pea and rice protein per pack. Real strength fuel, in gummy form."
            }
          }, {
            "type": "benefit",
            "settings": {
              "icon_key": "droplet",
              "accent": "pink",
              "title": "Zero Added Sugar",
              "description": "Naturally sweetened with allulose and stevia. Sweet hit, no crash, none of the guilt."
            }
          }, {
            "type": "benefit",
            "settings": {
              "icon_key": "candy",
              "accent": "yellow",
              "title": "Tastes Amazing",
              "description": "Natural mango flavour with the soft, pillowy chew of your favourite lolly bag."
            }
          }, {
            "type": "benefit",
            "settings": {
              "icon_key": "refresh",
              "accent": "purple",
              "title": "Boosts Recovery",
              "description": "Snack-sized post-workout fuel for faster recovery — or a mid-afternoon pick-me-up when cravings hit."
            }
          }
        ]
      }
    ]
  }
{% endschema %}