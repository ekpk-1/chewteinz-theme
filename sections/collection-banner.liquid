<div class="min-h-0 pt-20 sm:pt-24 md:pt-32 pb-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6 sm:mb-8">
      <div class="bg-gradient-to-r from-chewteinz-purple via-chewteinz-pink to-chewteinz-orange rounded-2xl shadow-xl p-4 sm:p-6 text-center">
        <p class="text-white font-display font-bold text-xl sm:text-2xl md:text-3xl mb-1">
          {{ section.settings.banner_title }}
        </p>
        <p class="text-white/90 font-body text-sm sm:text-base">
          {{ section.settings.banner_subtitle }}
        </p>
      </div>
    </div>

    <div class="text-center mb-8 sm:mb-10 md:mb-12">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-display font-bold mb-4 bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink bg-clip-text text-transparent px-4">
        {{ collection.title | default: "Shop All Flavors" }}
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-gray-600 font-body px-4">
        Every bag packed with 60g of delicious protein
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner Title",
      "default": "Now Available!"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner Subtitle",
      "default": "ChewTeinz Mango Madness is in stock"
    }
  ]
}
{% endschema %}
