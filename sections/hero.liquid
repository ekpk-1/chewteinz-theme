{%- liquid
  assign hero_image = section.settings.hero_image
  assign accent_word = section.settings.accent_word | default: 'actually'
  assign heading = section.settings.heading

  comment
    If the saved subheading is the legacy short stat string (or blank), fall
    back to a proper lede so the hero never looks empty.Merchants can still
    edit it from the customizer to override.
  endcomment
  assign subheading = section.settings.subheading
  assign legacy_short = '20g of protein'
  if subheading == blank or subheading contains legacy_short
    assign subheading = 'Real fruity gummies pulling double duty — 20g of plant-based protein, zero added sugar, naturally sweetened with allulose and stevia. Built to fuel post-workout cravings without the crash.'
  endif

  assign hero_secondary_link = section.settings.secondary_link | strip
  assign hero_secondary_opens_nutrition = false
  if hero_secondary_link == blank or hero_secondary_link == '#' or hero_secondary_link == '/#'
    assign hero_secondary_opens_nutrition = true
  endif
  assign nutrition_modal_product_name = section.settings.nutrition_modal_product_name | default: shop.name
-%}

<section class="hero" id="ct-top">
  <div class="ct-container hero__inner">
    <div class="hero__copy reveal" data-delay="1">
      <div class="hero__badge">
        <span></span>
        {{ section.settings.eyebrow | default: 'The smarter way to snack' }}
      </div>

      <h1 class="hero__title">
        {%- if heading contains accent_word and accent_word != blank -%}
          {%- assign parts = heading | split: accent_word -%}
          {{ parts[0] }}<em>{{ accent_word }}</em>
          {{ parts[1] }}
        {%- else -%}
          {{ heading }}
        {%- endif -%}
      </h1>

      <p class="hero__lede">{{ subheading }}</p>

      <div class="hero__ctas">
        {%- if section.settings.cta_text != blank -%}
          <a class="btn btn--lg btn--shadow" href="{{ section.settings.cta_link | default: '#ct-shop' }}">
            {{ section.settings.cta_text }}
            <span class="btn__arrow">
              <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
            </span>
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_text != blank -%}
          {%- if hero_secondary_opens_nutrition -%}
            <button
              type="button"
              class="btn btn--ghost btn--lg"
              data-open-nutrition
              data-product-name="{{ nutrition_modal_product_name | escape }}">
              {{ section.settings.secondary_text }}
            </button>
          {%- else -%}
            <a class="btn btn--ghost btn--lg" href="{{ hero_secondary_link }}">
              {{ section.settings.secondary_text }}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="hero__rating">
        <span aria-hidden="true">★★★★★</span>
        <strong>{{ section.settings.rating_text | default: '4.9/5 from early tasters' }}</strong>
      </div>

      <div class="hero__trust" aria-label="Key product benefits">
        <span style="--dot: var(--c-pink-deep)">{{ section.settings.trust_1 | default: 'Sugar free' }}</span>
        <span style="--dot: var(--c-green, #82A56B)">{{ section.settings.trust_2 | default: 'Plant based' }}</span>
        <span style="--dot: var(--c-orange)">{{ section.settings.stat_1_value | default: '20g' }} {{ section.settings.stat_1_label | default: 'Protein' }}</span>
        <span style="--dot: var(--c-purple)">{{ section.settings.trust_4 | default: 'No nasties' }}</span>
      </div>
    </div>

    <div
      class="hero__visual reveal"
      data-delay="2"
      aria-hidden="true">
      <span class="hero__halo"></span>
      <span class="hero__float hero__float--one"></span>
      <span class="hero__float hero__float--two"></span>
      <span class="hero__float hero__float--three"></span>
      <span class="hero__float hero__float--four"></span>
      {%- if hero_image != blank -%}
        <img
          class="hero__product"
          src="{{ hero_image | image_url: width: 800 }}"
          srcset="
            {{ hero_image | image_url: width: 400 }} 400w,
            {{ hero_image | image_url: width: 600 }} 600w,
            {{ hero_image | image_url: width: 800 }} 800w,
            {{ hero_image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 900px) 80vw, 520px"
          alt="{{ hero_image.alt | default: shop.name }}"
          loading="eager"
          width="{{ hero_image.width }}"
          height="{{ hero_image.height }}">
      {%- else -%}
        <img
          class="hero__product"
          src="{{ 'bag-mango.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="874"
          height="1184"
          loading="eager">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Hero",
    "settings": [
      {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Hero Image",
        "info": "Main product hero image. Falls back to a default if empty."
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Finally, candy that actually builds muscle."
      },
      {
        "type": "text",
        "id": "accent_word",
        "label": "Accent word",
        "info": "One word inside the heading rendered as the visual accent.",
        "default": "actually"
      },
      {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
        "default": "Real fruity gummies pulling double duty — 20g of plant-based protein, zero added sugar, naturally sweetened with allulose and stevia. Built to fuel post-workout cravings without the crash."
      }, {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "The smarter way to snack"
      }, {
        "type": "text",
        "id": "cta_text",
        "label": "Primary CTA Text",
        "default": "Shop Now"
      }, {
        "type": "url",
        "id": "cta_link",
        "label": "Primary CTA Link",
        "default": "/collections/all"
      }, {
        "type": "text",
        "id": "secondary_text",
        "label": "Secondary CTA Text",
        "default": "See nutrition"
      }, {
        "type": "url",
        "id": "secondary_link",
        "label": "Secondary CTA Link",
        "info": "Leave blank or use # to open the nutrition facts modal for this button. Otherwise set a real URL to navigate away."
      }, {
        "type": "text",
        "id": "nutrition_modal_product_name",
        "label": "Nutrition modal product name",
        "info": "Used when the secondary CTA opens the nutrition modal. Shown to screen readers. Blank uses your store name."
      }, {
        "type": "text",
        "id": "rating_text",
        "label": "Rating text",
        "default": "4.9/5 from early tasters"
      }, {
        "type": "text",
        "id": "trust_1",
        "label": "Trust pill 1",
        "default": "Sugar free"
      }, {
        "type": "text",
        "id": "trust_2",
        "label": "Trust pill 2",
        "default": "Plant based"
      }, {
        "type": "text",
        "id": "trust_4",
        "label": "Trust pill 4",
        "default": "No nasties"
      }, {
        "type": "header",
        "content": "Stat slab"
      }, {
        "type": "text",
        "id": "stat_1_value",
        "label": "Stat 1 value",
        "default": "20g"
      }, {
        "type": "text",
        "id": "stat_1_label",
        "label": "Stat 1 label",
        "default": "Protein"
      }, {
        "type": "text",
        "id": "stat_2_value",
        "label": "Stat 2 value",
        "default": "0g"
      }, {
        "type": "text",
        "id": "stat_2_label",
        "label": "Stat 2 label",
        "default": "Sugar"
      }, {
        "type": "text",
        "id": "stat_3_value",
        "label": "Stat 3 value",
        "default": "160"
      }, {
        "type": "text",
        "id": "stat_3_label",
        "label": "Stat 3 label",
        "default": "Calories"
      }, {
        "type": "text",
        "id": "stat_4_value",
        "label": "Stat 4 value",
        "default": "0"
      }, {
        "type": "text",
        "id": "stat_4_label",
        "label": "Stat 4 label",
        "default": "Guilt"
      }
    ]
  }
{% endschema %}