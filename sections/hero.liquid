{%- liquid
  assign hero_image = section.settings.hero_image
  assign accent_word = section.settings.accent_word | default: 'actually'
  assign heading = section.settings.heading

  comment
    If the saved subheading is the legacy short stat string (or blank), fall
    back to a proper lede so the hero never looks empty.Merchants can still
    edit it from the customizer to override.
  endcomment
  assign subheading = section.settings.subheading
  assign legacy_short = '20g of protein'
  if subheading == blank or subheading contains legacy_short
    assign subheading = 'Real fruity gummies pulling double duty — 20g of plant-based protein, zero added sugar, naturally sweetened with allulose and stevia. Built to fuel post-workout cravings without the crash.'
  endif
-%}

<section class="hero">
  {% render 'floating-candy'
    , preset: 'hero' %}

  <div class="ct-container hero__inner">
    <div class="hero__copy reveal" data-delay="1">
      <h1 class="hero__title">
        {%- if heading contains accent_word and accent_word != blank -%}
          {%- assign parts = heading | split: accent_word -%}
          {{ parts[0] }}<em>{{ accent_word }}</em>
          {{ parts[1] }}
        {%- else -%}
          {{ heading }}
        {%- endif -%}
      </h1>

      <p class="hero__lede">{{ subheading }}</p>

      <div class="hero__ctas">
        {%- if section.settings.cta_text != blank -%}
          <a class="btn btn--white btn--lg" href="{{ section.settings.cta_link | default: '#' }}">
            {{ section.settings.cta_text }}
            <span class="btn__arrow">
              <svg class="w-[22px] h-[22px]" aria-hidden="true"><use href="#i-arrow-right" /></svg>
            </span>
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_text != blank -%}
          <a class="btn btn--ghost-white btn--lg" href="{{ section.settings.secondary_link | default: '#' }}">
            {{ section.settings.secondary_text }}
          </a>
        {%- endif -%}
      </div>

      <div class="hero__stats stat-slab stat-slab--frosted" aria-label="Key product stats">
        <div class="stat-slab__cell">
          <div class="stat-slab__num">{{ section.settings.stat_1_value | default: '20g' }}</div>
          <div class="stat-slab__label">{{ section.settings.stat_1_label | default: 'Protein' }}</div>
        </div>
        <div class="stat-slab__cell">
          <div class="stat-slab__num">{{ section.settings.stat_2_value | default: '0g' }}</div>
          <div class="stat-slab__label">{{ section.settings.stat_2_label | default: 'Sugar' }}</div>
        </div>
        <div class="stat-slab__cell">
          <div class="stat-slab__num">{{ section.settings.stat_3_value | default: '160' }}</div>
          <div class="stat-slab__label">{{ section.settings.stat_3_label | default: 'Calories' }}</div>
        </div>
        <div class="stat-slab__cell">
          <div class="stat-slab__num">{{ section.settings.stat_4_value | default: '0' }}</div>
          <div class="stat-slab__label">{{ section.settings.stat_4_label | default: 'Guilt' }}</div>
        </div>
      </div>
    </div>

    <div
      class="hero__visual reveal"
      data-delay="2"
      aria-hidden="true">
      <span class="hero__halo"></span>
      {%- if hero_image != blank -%}
        <img
          class="hero__product"
          src="{{ hero_image | image_url: width: 800 }}"
          srcset="
            {{ hero_image | image_url: width: 400 }} 400w,
            {{ hero_image | image_url: width: 600 }} 600w,
            {{ hero_image | image_url: width: 800 }} 800w,
            {{ hero_image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 900px) 80vw, 520px"
          alt="{{ hero_image.alt | default: shop.name }}"
          loading="eager"
          width="{{ hero_image.width }}"
          height="{{ hero_image.height }}">
      {%- else -%}
        <img
          class="hero__product"
          src="https://cdn.shopify.com/s/files/1/0991/6592/9553/files/Landing_page.png?v=1778408038"
          alt="{{ shop.name }}"
          width="1024"
          height="1024">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Hero",
    "settings": [
      {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Hero Image",
        "info": "Main product hero image. Falls back to a default if empty."
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Finally, candy that actually builds muscle."
      },
      {
        "type": "text",
        "id": "accent_word",
        "label": "Accent word",
        "info": "One word inside the heading rendered as the visual accent.",
        "default": "actually"
      },
      {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
        "default": "Real fruity gummies pulling double duty — 20g of plant-based protein, zero added sugar, naturally sweetened with allulose and stevia. Built to fuel post-workout cravings without the crash."
      }, {
        "type": "text",
        "id": "cta_text",
        "label": "Primary CTA Text",
        "default": "Shop Now"
      }, {
        "type": "url",
        "id": "cta_link",
        "label": "Primary CTA Link",
        "default": "/collections/all"
      }, {
        "type": "text",
        "id": "secondary_text",
        "label": "Secondary CTA Text",
        "default": "See nutrition"
      }, {
        "type": "url",
        "id": "secondary_link",
        "label": "Secondary CTA Link"
      }, {
        "type": "header",
        "content": "Stat slab"
      }, {
        "type": "text",
        "id": "stat_1_value",
        "label": "Stat 1 value",
        "default": "20g"
      }, {
        "type": "text",
        "id": "stat_1_label",
        "label": "Stat 1 label",
        "default": "Protein"
      }, {
        "type": "text",
        "id": "stat_2_value",
        "label": "Stat 2 value",
        "default": "0g"
      }, {
        "type": "text",
        "id": "stat_2_label",
        "label": "Stat 2 label",
        "default": "Sugar"
      }, {
        "type": "text",
        "id": "stat_3_value",
        "label": "Stat 3 value",
        "default": "160"
      }, {
        "type": "text",
        "id": "stat_3_label",
        "label": "Stat 3 label",
        "default": "Calories"
      }, {
        "type": "text",
        "id": "stat_4_value",
        "label": "Stat 4 value",
        "default": "0"
      }, {
        "type": "text",
        "id": "stat_4_label",
        "label": "Stat 4 label",
        "default": "Guilt"
      }
    ]
  }
{% endschema %}