<section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple overflow-hidden">
  <div class="absolute inset-0 overflow-hidden">
    {%- assign positions = "5:10,15:25,8:60,12:85,25:15,30:75,20:45,40:8,45:92,50:5,55:88,60:12,70:45,75:22,68:70,80:55,85:15,90:80,92:40,88:65" | split: "," -%}
    {%- assign rotations = "0,18,-25,40,-35,55,-48,70,-60,85,-75,95,-88,110,-105,125,-120,140,-135,155" | split: "," -%}
    {%- for pos in positions -%}
      {%- assign coords = pos | split: ":" -%}
      {%- assign idx = forloop.index0 -%}
      {%- assign delay_val = idx | times: 0.3 | modulo: 5 -%}
      {%- assign dur_base = idx | modulo: 4 | plus: 5 -%}
      <img
        src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTAzp81qYdzGFpfVKBbR6Qy9iWxIh3krP4LwZS"
        alt=""
        class="absolute w-8 h-8 sm:w-12 sm:h-12 md:w-16 md:h-16 opacity-20 animate-float"
        style="left:{{ coords[0] }}%;top:{{ coords[1] }}%;animation-delay:{{ delay_val }}s;animation-duration:{{ dur_base }}s;transform:rotate({{ rotations[idx] }}deg)"
        loading="lazy"
      >
    {%- endfor -%}
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <div class="relative mb-4 sm:mb-6 md:mb-[2vh] flex justify-center mt-8 sm:mt-12 md:top-[5vh]">
      <img
        src="https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTZWfCRu4PgqRxlpeEzvaLNWk8fbGJSHDVM2I5"
        alt="{{ shop.name }}"
        class="w-[90%] max-w-sm sm:max-w-xl md:max-w-2xl h-auto drop-shadow-2xl animate-bounce-slow"
      >
    </div>

    <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-display font-semibold text-white text-shadow mb-4 sm:mb-6 md:mb-8 px-4">
      {{ section.settings.heading }}
    </h2>

    <p class="text-lg sm:text-xl md:text-2xl text-white/90 mb-8 sm:mb-10 md:mb-12 font-body px-4">
      {{ section.settings.subheading }}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center px-4">
      <a
        href="{{ section.settings.cta_link }}"
        class="group relative px-6 py-3 sm:px-8 sm:py-4 bg-white text-chewteinz-purple font-display font-bold text-lg sm:text-xl rounded-full shadow-2xl hover:scale-110 transition-transform w-full sm:w-auto max-w-xs sm:max-w-none text-center"
      >
        <span class="relative z-10">{{ section.settings.cta_text }}</span>
        <span class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity">{% render 'icon', icon: 'sparkles', size: 20 %}</span>
      </a>
    </div>

    <div class="mt-10 sm:mt-12 md:mt-16 flex justify-center gap-4 sm:gap-6 md:gap-8 text-white px-4">
      <div class="text-center">
        <div class="text-2xl sm:text-3xl md:text-4xl font-display font-bold">60g</div>
        <div class="text-sm sm:text-base md:text-lg font-body">Protein</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl md:text-4xl font-display font-bold">0g</div>
        <div class="text-sm sm:text-base md:text-lg font-body">Sugar</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl md:text-4xl font-display font-bold">100%</div>
        <div class="text-sm sm:text-base md:text-lg font-body">Delicious</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-4 sm:bottom-6 md:bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="text-white text-2xl sm:text-3xl md:text-4xl">&darr;</div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The smarter way to snack."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Snack happy and guilt free"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link",
      "default": "/collections/all"
    }
  ]
}
{% endschema %}
