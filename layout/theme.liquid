<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{{ page_title }}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% render 'seo-meta' %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  {%- comment -%}
    Favicon links MUST come after {{ content_for_header }} so they override
    Shopify's auto-injected favicon (from Online Store > Preferences).
  {%- endcomment -%}
  {%- if settings.favicon != blank -%}
    {%- assign favicon_url = settings.favicon | image_url: width: 180 -%}
  {%- else -%}
    {%- assign favicon_url = 'https://1pg86aook1.ufs.sh/f/pN2g9q3wzUsTZWfCRu4PgqRxlpeEzvaLNWk8fbGJSHDVM2I5' -%}
  {%- endif -%}
  <link rel="icon" type="image/png" sizes="32x32" href="{{ favicon_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ favicon_url }}">
  <link rel="shortcut icon" type="image/png" href="{{ favicon_url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ favicon_url }}">

  <script>
    window.chewteinzSettings = {
      klaviyoPublicKey: {{ settings.klaviyo_public_key | json }},
      klaviyoSubscribeListId: {{ settings.klaviyo_subscribe_list_id | json }},
      klaviyoNotifyListId: {{ settings.klaviyo_notify_list_id | json }},
      supabaseUrl: {{ settings.supabase_url | json }},
      supabaseAnonKey: {{ settings.supabase_anon_key | json }},
      makeWebhookUrl: {{ settings.make_webhook_url | json }},
      subscribeModalEnabled: {% if settings.subscribe_modal_enabled == false %}false{% else %}true{% endif %},
      subscribeModalDelaySeconds: {% if settings.subscribe_modal_delay != blank %}{{ settings.subscribe_modal_delay }}{% else %}10{% endif %}
    };
  </script>
</head>
<body class="min-h-screen smooth-scroll bg-white text-chewteinz-ink">
  {% render 'icon-sprite' %}

  {% section 'announcement-banner' %}
  {% section 'header' %}

  {%- comment -%}
    The announcement banner (h-10 sm:h-12) and site header are both fixed at
    the top of the viewport. Reserve space for them so page content doesn't
    sit underneath. Sections that intentionally bleed under the chrome can
    override with their own padding.
  {%- endcomment -%}
  <main class="pt-[104px] sm:pt-[124px]">
    {{ content_for_layout }}
  </main>

  {% section 'cart-drawer' %}
  {% section 'footer' %}

  {% render 'subscribe-modal' %}
  {% render 'gift-modal' %}
  {% render 'nutrition-modal' %}
  {% render 'notify-modal' %}
  {% render 'preorder-modal' %}

  {{ 'cart.js' | asset_url | script_tag }}
  {{ 'modals.js' | asset_url | script_tag }}
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
