<div id="nutrition-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none" aria-hidden="true">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="window.modals.closeNutrition()"></div>

  <div class="relative bg-white rounded-3xl shadow-2xl max-w-4xl w-full overflow-hidden transform transition-all duration-300 scale-95" id="nutrition-modal-content">
    <button
      type="button"
      onclick="window.modals.closeNutrition()"
      class="absolute top-4 right-4 z-10 p-2 rounded-full bg-white/90 hover:bg-white transition-colors shadow-md"
      aria-label="Close nutrition information"
      tabindex="0"
    >
      {% render 'icon', icon: 'x', size: 20, class: 'text-gray-600' %}
    </button>

    <div class="p-4 sm:p-6 max-h-[calc(100vh-80px)] overflow-y-auto">
      <p class="sr-only" id="nutrition-product-name"></p>
      <img
        id="nutrition-info-image"
        class="w-full h-auto rounded-xl"
        src="{{ 'nutrition-panel.png' | asset_url }}"
        alt="ChewTeinz Mango Madness Protein Gummies — nutrition facts, ingredients and product highlights"
        width="1200"
        height="1200"
        loading="lazy"
      >

      <button type="button" onclick="window.modals.closeNutrition()" class="w-full mt-4 py-3 bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink text-white font-display font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-lg">
        Close
      </button>
    </div>
  </div>
</div>
