<div id="subscribe-modal" class="fixed inset-0 z-[70] flex items-center justify-center p-4 sm:p-6 transition-opacity duration-300 opacity-0 pointer-events-none overflow-y-auto" aria-hidden="true">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="window.modals.closeSubscribe()"></div>

  <div class="relative w-full max-w-[900px] mx-auto my-auto transform transition-all duration-300 scale-95" id="subscribe-modal-content">
    <div class="signup-modal">
      {%- comment -%} Left: editable image (desktop left / mobile row 1) {%- endcomment -%}
      <div class="signup-modal__media" aria-hidden="true">
        <button
          type="button"
          onclick="window.modals.closeSubscribe()"
          class="signup-modal__close"
          aria-label="Close"
          tabindex="0">
          {% render 'icon', icon: 'x', size: 20, class: 'text-chewteinz-ink-soft' %}
        </button>
        {%- if settings.subscribe_modal_image != blank -%}
          <img
            src="{{ settings.subscribe_modal_image | image_url: width: 900 }}"
            srcset="
              {{ settings.subscribe_modal_image | image_url: width: 480 }} 480w,
              {{ settings.subscribe_modal_image | image_url: width: 720 }} 720w,
              {{ settings.subscribe_modal_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 767px) 100vw, 450px"
            alt=""
            width="900"
            height="1200"
            loading="lazy">
        {%- else -%}
          <img
            src="{{ 'subscribe-modal-image.png' | asset_url }}"
            alt=""
            width="900"
            height="1200"
            loading="lazy">
        {%- endif -%}
      </div>

      {%- comment -%} Right: signup form (desktop right / mobile row 2) {%- endcomment -%}
      <div class="signup-modal__panel">
        <div class="signup-modal__stage">
          <div id="subscribe-form-section" class="signup-modal__body">
            <h2 class="signup-modal__title">Get Exclusive Perks!</h2>
            <p class="signup-modal__lede">Join our VIP list for special offers &amp; early access</p>

            <div class="signup-modal__promo">
              <div class="signup-modal__promo-value">10% OFF</div>
              <div class="signup-modal__promo-label">Your First Order</div>
            </div>

            <p id="subscribe-flavor-note" class="signup-modal__flavor-note hidden">
              Plus early access when <span id="subscribe-flavor-name"></span> drops.
            </p>

            <form id="subscribe-form" class="signup-modal__form" onsubmit="return window.modals.handleSubscribeSubmit(event)">
              <div>
                <input
                  type="email"
                  id="subscribe-email"
                  placeholder="Enter your email address"
                  class="signup-modal__input"
                  autocomplete="email"
                  required>
                <div id="subscribe-error" class="hidden mt-2">
                  <div class="flex items-center gap-2 text-red-500 text-sm font-body">
                    {% render 'icon', icon: 'alert-circle', size: 16 %}
                    <span id="subscribe-error-text"></span>
                  </div>
                </div>
              </div>
              <button type="submit" id="subscribe-submit-btn" class="btn btn--gradient w-full">
                Get My 10% Off
              </button>
            </form>

            <p class="signup-modal__privacy">We respect your privacy. Unsubscribe anytime.</p>
            <button type="button" onclick="window.modals.closeSubscribe()" class="signup-modal__dismiss">
              No thanks, I'll pay full price
            </button>
          </div>

          <div id="subscribe-success-section" class="hidden signup-modal__body signup-modal__success">
            <div class="signup-modal__success-icon">
              {% render 'icon', icon: 'mail', size: 36, class: 'text-white' %}
            </div>
            <h3 class="signup-modal__title">Success!</h3>
            <p class="signup-modal__lede">Preparing your gift...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
