<div id="subscribe-modal" class="fixed inset-0 z-[70] flex items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none" aria-hidden="true">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="window.modals.closeSubscribe()"></div>

  <div class="relative bg-white rounded-3xl shadow-2xl max-w-lg w-full overflow-hidden transform transition-all duration-300 scale-95" id="subscribe-modal-content">
    <button
      type="button"
      onclick="window.modals.closeSubscribe()"
      class="absolute top-4 right-4 z-10 p-2 rounded-full bg-white/90 hover:bg-white transition-colors shadow-lg"
      aria-label="Close"
      tabindex="0"
    >
      {% render 'icon', icon: 'x', size: 20, class: 'text-gray-600' %}
    </button>

    <div class="relative bg-gradient-to-br from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple p-8 sm:p-10 text-center overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        {% for i in (1..8) %}
          <span class="absolute text-white animate-sparkle" style="left:{{ i | times: 12 }}%;top:{{ i | times: 10 | plus: 5 }}%;animation-delay:{{ i | times: 0.25 }}s">
            {% render 'icon', icon: 'sparkles', size: 16 %}
          </span>
        {% endfor %}
      </div>
      <div class="relative">
        <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center mx-auto mb-4">
          {% render 'icon', icon: 'mail', size: 40, class: 'text-white' %}
        </div>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mb-3 drop-shadow-lg">Get Exclusive Perks!</h2>
        <p class="text-lg sm:text-xl text-white/95 font-body drop-shadow">Join our VIP list for special offers &amp; early access</p>
      </div>
    </div>

    <div class="p-6 sm:p-8">
      <div id="subscribe-form-section">
        <div class="bg-gradient-to-r from-yellow-50 via-pink-50 to-purple-50 rounded-2xl p-6 mb-6 text-center">
          <div class="text-4xl font-display font-bold text-gray-800 mb-2">10% OFF</div>
          <div class="text-lg text-gray-700 font-body">Your First Order</div>
        </div>

        <form id="subscribe-form" class="space-y-4" onsubmit="return window.modals.handleSubscribeSubmit(event)">
          <div>
            <input type="text" id="subscribe-name" placeholder="Enter your name" class="w-full px-4 py-3 rounded-full border-2 border-gray-200 focus:border-chewteinz-purple focus:outline-none transition-colors font-body text-gray-800 placeholder-gray-400">
          </div>
          <div>
            <input type="email" id="subscribe-email" placeholder="Enter your email address" class="w-full px-4 py-3 rounded-full border-2 border-gray-200 focus:border-chewteinz-purple focus:outline-none transition-colors font-body text-gray-800 placeholder-gray-400">
            <div id="subscribe-error" class="hidden mt-2">
              <div class="flex items-center gap-2 text-red-500 text-sm font-body">
                {% render 'icon', icon: 'alert-circle', size: 16 %}
                <span id="subscribe-error-text"></span>
              </div>
            </div>
          </div>
          <button type="submit" id="subscribe-submit-btn" class="w-full py-3 bg-gradient-to-r from-chewteinz-purple to-chewteinz-pink text-white font-display font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100">
            Get My 10% Off
          </button>
        </form>

        <p class="text-xs text-gray-500 text-center mt-4 font-body">We respect your privacy. Unsubscribe anytime.</p>
        <button type="button" onclick="window.modals.closeSubscribe()" class="w-full mt-3 py-2 text-gray-600 font-body text-sm hover:text-gray-800 transition-colors">
          No thanks, I'll pay full price
        </button>
      </div>

      <div id="subscribe-success-section" class="hidden text-center py-8">
        <div class="w-20 h-20 bg-gradient-to-br from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple rounded-full flex items-center justify-center mx-auto mb-4 animate-bounce">
          {% render 'icon', icon: 'mail', size: 40, class: 'text-white' %}
        </div>
        <h3 class="text-2xl font-display font-bold text-gray-800 mb-2">Success!</h3>
        <p class="text-gray-600 font-body">Preparing your gift...</p>
      </div>
    </div>
  </div>
</div>
