{%- comment -%}
  Renders a Lucide icon as inline SVG.
  Usage: {% render 'icon', icon: 'shopping-cart', size: 24, class: 'text-white' %}
{%- endcomment -%}

{%- liquid
  unless size
    assign size = 24
  endunless
  unless class
    assign class = ''
  endunless
-%}

