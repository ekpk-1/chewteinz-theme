{%- comment -%}
  Judge.me widgets snippet (v3 / 2025+ install code).

  Source: Judge.me dashboard → Install on theme → "Manual install code".
  Do not strip the `data-entry-point`, `data-entry-key`, the legacy fallback
  `<div class="jdgm-legacy-widget-content">`, or the inline `jdgm.data`
  seeding script — Judge.me's v3 widget engine relies on all of them.

  Usage:
    Preview badge:  {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', product: product %}
    Review widget:  {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget',  product: product %}
{%- endcomment -%}

{%- if widget_type == 'judgeme_preview_badge' -%}

  <!-- Start of Judge.me preview badge -->
  <div
    class="jdgm-widget jdgm-preview-badge"
    data-id="{{ product.id }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-template="{{ template.name }}"
    data-auto-install="false"></div>
  <!-- End of Judge.me preview badge -->

{%- elsif widget_type == 'judgeme_review_widget' -%}

  <!-- Start of Judge.me code -->
  {% assign has_legacy = false %}
  {% if product.metafields.judgeme.widget.size > 20 %}
    {% assign has_legacy = true %}
  {% endif %}
  <div style="clear:both"></div>
  <div
    id="judgeme_product_reviews"
    class="jdgm-widget jdgm-review-widget"
    data-product-title="{{ product.title | escape }}"
    data-id="{{ product.id }}"
    data-product-id="{{ product.id }}"
    data-widget="review"
    data-auto-install="false"
    data-shop-reviews-count="{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}"
    data-entry-point="review_widget.js"
    data-entry-key="review-widget/main.js">
    {% if has_legacy %}
      <div class="jdgm-legacy-widget-content" style="display: none;">
        {{ product.metafields.judgeme.widget }}
      </div>
    {% endif %}
  </div>
  {% if product.metafields.judgeme.review_widget_data %}
    <script>
      jdgm.data ||= {};
      jdgm.data.reviewWidget ||= {};
      jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }};
    </script>
  {% endif %}
  <!-- End of Judge.me code -->

{%- endif -%}
