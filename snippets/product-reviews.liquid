{%- comment -%}
  ChewTeinz product reviews snippet.

  Drop this snippet into any product context (e.g. featured-product.liquid):
  {% render 'product-reviews', product: product %}

  Powered by Judge.me. The Judge.me app embed block must be enabled in the
  theme editor (Online Store > Themes > Customize > App embeds > Judge.me Core).
  When enabled, Judge.me's JS hydrates the `.jdgm-review-widget` div below
  with the star summary, the review list, and a "Write a review" button.

  Rating values come from the standard `reviews` metafield namespace, which
  Judge.me syncs automatically (Settings > Integrations > Shopify metafields
  in the Judge.me dashboard).
{%- endcomment -%}

{%- if product != blank -%}
  {%- assign rating = product.metafields.reviews.rating.value -%}
  {%- assign rating_count = product.metafields.reviews.rating_count | plus: 0 -%}

  <section class="py-10 sm:py-14 md:py-16 mt-10 sm:mt-12 md:mt-16 bg-gradient-to-br from-chewteinz-blue to-chewteinz-purple rounded-2xl w-full" id="product-reviews">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-6 sm:mb-8">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-display font-bold mb-2 text-white text-shadow">
          What Our Customers Are Saying
        </h2>

        {%- if rating != blank and rating_count > 0 -%}
          {%- assign full_stars = rating.rating | floor -%}
          <div class="flex items-center justify-center gap-1 mb-2" aria-label="Rated {{ rating.rating }} out of {{ rating.scale_max }}">
            {%- for i in (1..rating.scale_max) -%}
              <svg
                class="w-5 h-5 sm:w-6 sm:h-6 {% if i <= full_stars %}text-chewteinz-yellow{% else %}text-white/30{% endif %}"
                fill="currentColor"
                viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118l-3.366-2.446a1 1 0 00-1.176 0l-3.367 2.446c-.784.57-1.838-.196-1.539-1.118l1.286-3.957a1 1 0 00-.363-1.118L2.05 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.286-3.957z" />
              </svg>
            {%- endfor -%}
          </div>
          <p class="text-sm sm:text-base text-white/90 font-body">
            {{ rating.rating }} out of {{ rating.scale_max }} · {{ rating_count }} review{% if rating_count != 1 %}s{% endif %}
          </p>
        {%- else -%}
          <p class="text-sm sm:text-base text-white/90 font-body">
            Be the first to share your thoughts.
          </p>
        {%- endif -%}
      </div>

      <div class="bg-white rounded-xl p-4 sm:p-6 jdgm-widget-host">
        {% render 'judgeme_widgets'
          , widget_type: 'judgeme_review_widget'
          , product: product %}
      </div>
    </div>
  </section>

  {%- comment -%}
    Theme overrides for Judge.me v3 (`jm-*` Vue component classes). v3 themes
    via CSS custom properties on `.jm-review-widget` and per-review wrappers,
    so the cleanest approach is overriding those vars at the `.jdgm-widget-host`
    scope and adding gradient/font tweaks to specific elements.
  {%- endcomment -%}
  <style>
    .jdgm-widget-host {
      --chewteinz-yellow: #FFE55C;
      --chewteinz-pink: #FFB3E6;
      --chewteinz-purple: #C8A2F0;
      --chewteinz-orange: #FFB380;
    }

    .jdgm-widget-host .jm-review-widget,
    .jdgm-widget-host .jm-review-item,
    .jdgm-widget-host .jm-star-rating {
      --jm-review-widget-star-and-histogram-color: var(--chewteinz-yellow) !important;
      --jm-widget-primary-color: var(--chewteinz-purple) !important;
      --jm-review-widget-text-color: #1F2937 !important;
      --jm-review-widget-lighter-text-color: #6B7280 !important;
    }

    .jdgm-widget-host .jm-star-rating__font-icon {
      color: var(--chewteinz-yellow) !important;
    }

    .jdgm-widget-host .jm-button.jm-button--primary {
      background: linear-gradient(to right, var(--chewteinz-purple), var(--chewteinz-pink)) !important;
      background-color: transparent !important;
      color: #FFFFFF !important;
      border: none !important;
      border-radius: 9999px !important;
      font-family: 'Fredoka'
      , system-ui
      , sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: 0.01em;
      padding: 0.7rem 1.4rem !important;
      box-shadow: 0 6px 16px rgba(200, 162, 240, 0.35) !important;
      transition: transform 0.2s ease
      , box-shadow 0.2s ease !important;
    }
    .jdgm-widget-host .jm-button.jm-button--primary:hover {
      transform: scale(1.04);
      box-shadow: 0 8px 22px rgba(255, 179, 230, 0.45) !important;
    }

    .jdgm-widget-host .jm-button.jm-button--secondary {
      border-radius: 9999px !important;
      border-color: rgba(200, 162, 240, 0.5) !important;
      color: #4B5563 !important;
      font-family: 'Nunito'
      , system-ui
      , sans-serif !important;
      font-weight: 600 !important;
      transition: background 0.2s ease
      , border-color 0.2s ease !important;
    }
    .jdgm-widget-host .jm-button.jm-button--secondary:hover {
      background: rgba(200, 162, 240, 0.08) !important;
      border-color: var(--chewteinz-purple) !important;
    }

    .jdgm-widget-host .jm-sort-filter__select,
    .jdgm-widget-host .jdgm-sort-dropdown {
      border-radius: 9999px !important;
      border: 1px solid rgba(200, 162, 240, 0.5) !important;
      font-family: 'Nunito'
      , system-ui
      , sans-serif !important;
      color: #4B5563 !important;
      padding: 0.4rem 2rem 0.4rem 1.8rem !important;
      cursor: pointer;
    }

    .jdgm-widget-host .jm-reviewer-avatar,
    .jdgm-widget-host .jm-reviewer-avatar__initial {
      background: linear-gradient(135deg, var(--chewteinz-purple), var(--chewteinz-pink)) !important;
      border-radius: 9999px !important;
      width: 2.75rem !important;
      height: 2.75rem !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      box-shadow: 0 2px 6px rgba(200, 162, 240, 0.3);
    }
    .jdgm-widget-host .jm-reviewer-avatar__initial .jm-text {
      color: #FFFFFF !important;
      font-family: 'Fredoka'
      , system-ui
      , sans-serif !important;
      font-weight: 700 !important;
    }

    .jdgm-widget-host .jm-text {
      font-family: 'Nunito'
      , system-ui
      , sans-serif !important;
    }
    .jdgm-widget-host .jm-review-content__title,
    .jdgm-widget-host .jm-average-rating-display .jm-text:first-child {
      font-family: 'Fredoka'
      , system-ui
      , sans-serif !important;
      color: #1F2937 !important;
    }
    .jdgm-widget-host .jm-reviewer-info__name {
      color: #1F2937 !important;
      font-weight: 700 !important;
    }

    .jdgm-widget-host .jm-review-item {
      border-color: rgba(200, 162, 240, 0.25) !important;
    }

    .jdgm-widget-host .jm-media-grid__container img,
    .jdgm-widget-host .jm-review-item img {
      border-radius: 0.75rem !important;
    }


    /*
   Hide v3 widget header chrome: rating average, review count,
   filter dropdown, sort dropdown, and the empty media gallery preview.
   The "Write a review" button stays.
*/
    .jdgm-widget-host .jm-average-rating-display,
    .jdgm-widget-host .jm-custom-answer-filter,
    .jdgm-widget-host .jm-sort-filter,
    .jdgm-widget-host .jm-review-widget-minimal-header__filters,
    .jdgm-widget-host .jm-media-preview,
    .jdgm-widget-host .jm-media-grid {
      display: none !important;
    }


    /*
   Collapse the now-empty stacks so the button can truly center.
   :has() targets the wrapper that held .jm-average-rating-display.
*/
    .jdgm-widget-host .jm-review-widget__header .jm-stack:has(.jm-average-rating-display) {
      display: none !important;
    }

    .jdgm-widget-host .jm-review-widget__header .jm-cluster {
      --cluster-justify: center !important;
    }

    /* Tighten the empty space above the "Write a review" button. */
    .jdgm-widget-host .jm-review-widget {
      padding-top: 12px !important;
      padding-bottom: 0 !important;
    }


    /*
   Carousel layout: horizontal scroll-snap rail of review cards.
   v3 keeps the legacy `.jdgm-review-list` class on the list container,
   so we flip it from a vertical stack into a horizontal flex row.
*/
    .jdgm-widget-host .jdgm-review-list {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 0.5rem;
      -webkit-overflow-scrolling: touch;
      gap: 1rem !important;
      padding: 0.25rem 0.25rem 1rem !important;
      scrollbar-width: thin;
      scrollbar-color: rgba(200, 162, 240, 0.5) transparent;
      scroll-behavior: smooth;
    }
    .jdgm-widget-host .jdgm-review-list::-webkit-scrollbar {
      height: 6px;
    }
    .jdgm-widget-host .jdgm-review-list::-webkit-scrollbar-thumb {
      background: rgba(200, 162, 240, 0.5);
      border-radius: 9999px;
    }
    .jdgm-widget-host .jdgm-review-list::-webkit-scrollbar-track {
      background: transparent;
    }

    /* One review per slide, full width. */
    .jdgm-widget-host .jm-review-item {
      flex: 0 0 100% !important;
      min-width: 0 !important;
      max-width: none !important;
      scroll-snap-align: start;
      background: #FAFAFB;
      border: 1px solid rgba(200, 162, 240, 0.25) !important;
      border-radius: 1rem;
      padding: 2.5rem !important;
      box-shadow: 0 2px 8px rgba(200, 162, 240, 0.12);
    }


    /*
   Stack avatar+name above the stars instead of side-by-side.
   Targets the review header row so reviewer info sits on top
   and the star rating drops below it.
*/
    .jdgm-widget-host .jm-review-item__header {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 0.4rem !important;
    }
    .jdgm-widget-host .jm-review-item__header .jm-reviewer-info {
      order: 1;
    }
    .jdgm-widget-host .jm-review-item__header .jm-star-rating {
      order: 2;
      margin-left: 3.4rem;
      /* aligns under the name, past the avatar */
    }

    /* Carousel arrow buttons (injected by JS into the body container). */
    .jdgm-widget-host .jm-review-widget__body {
      position: relative;
    }
    .jdgm-carousel-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 9999px;
      background: #FFFFFF;
      border: 1px solid rgba(200, 162, 240, 0.4);
      color: #6B7280;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(200, 162, 240, 0.3);
      z-index: 5;
      transition: opacity 0.2s ease
      , transform 0.2s ease
      , background 0.2s ease
      , color 0.2s ease;
      padding: 0;
    }
    .jdgm-carousel-arrow:hover {
      background: linear-gradient(to right, var(--chewteinz-purple), var(--chewteinz-pink));
      color: #FFFFFF;
      border-color: transparent;
    }
    .jdgm-carousel-arrow:active {
      transform: translateY(-50%) scale(0.95);
    }
    .jdgm-carousel-arrow svg {
      width: 1.25rem;
      height: 1.25rem;
    }
    .jdgm-carousel-arrow--prev {
      left: -0.75rem;
    }
    .jdgm-carousel-arrow--next {
      right: -0.75rem;
    }
    .jdgm-carousel-arrow.is-disabled {
      opacity: 0;
      pointer-events: none;
    }

    /* Slide counter ("1 / 5"). */
    .jdgm-carousel-counter {
      display: none;
      text-align: center;
      margin-top: 0.75rem;
      font-family: 'Nunito'
      , system-ui
      , sans-serif;
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.85);
      letter-spacing: 0.05em;
    }
    .jdgm-widget-host + .jdgm-carousel-counter {
      color: #4B5563;
    }
  </style>

  <script>
    (function () {
      var INIT_ATTR = 'data-jdgm-carousel-ready';

      function buildArrow(direction, label) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'jdgm-carousel-arrow jdgm-carousel-arrow--' + direction;
        btn.setAttribute('aria-label', label);
        var path = direction === 'prev' ? '15 18 9 12 15 6' : '9 18 15 12 9 6';
        btn.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="' +
          path +
          '"></polyline></svg>';
        return btn;
      }

      function getStep(list) {
        var first = list.querySelector('.jm-review-item');
        if (!first) return list.clientWidth;
        var style = window.getComputedStyle(list);
        var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
        return first.getBoundingClientRect().width + gap;
      }

      function init(list) {
        if (list.getAttribute(INIT_ATTR)) return;
        list.setAttribute(INIT_ATTR, '1');

        var body = list.closest('.jm-review-widget__body') || list.parentElement;
        if (!body) return;

        var prev = buildArrow('prev', 'Previous review');
        var next = buildArrow('next', 'Next review');
        body.appendChild(prev);
        body.appendChild(next);

        var counter = document.createElement('div');
        counter.className = 'jdgm-carousel-counter';
        body.parentElement && body.parentElement.appendChild(counter);

        function totalSlides() {
          return list.querySelectorAll('.jm-review-item').length;
        }

        function currentIndex() {
          var step = getStep(list);
          if (step <= 0) return 0;
          return Math.round(list.scrollLeft / step);
        }

        function update() {
          var total = totalSlides();
          var idx = currentIndex();
          var atStart = list.scrollLeft <= 1;
          var atEnd = list.scrollLeft + list.clientWidth >= list.scrollWidth - 1;
          prev.classList.toggle('is-disabled', atStart);
          next.classList.toggle('is-disabled', atEnd);
          if (total <= 1) {
            prev.classList.add('is-disabled');
            next.classList.add('is-disabled');
            counter.textContent = '';
          } else {
            counter.textContent = (idx + 1) + ' / ' + total;
          }
        }

        prev.addEventListener('click', function () {
          list.scrollBy({ left: -getStep(list), behavior: 'smooth' });
        });
        next.addEventListener('click', function () {
          list.scrollBy({ left: getStep(list), behavior: 'smooth' });
        });
        list.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        update();
      }

      function scan() {
        document
          .querySelectorAll('.jdgm-widget-host .jdgm-review-list')
          .forEach(init);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scan);
      } else {
        scan();
      }

      // Judge.me v3 hydrates asynchronously — re-scan when it injects content.
      var hosts = document.querySelectorAll('.jdgm-widget-host');
      hosts.forEach(function (host) {
        new MutationObserver(scan).observe(host, {
          childList: true,
          subtree: true,
        });
      });
    })();
  </script>
{%- endif -%}