<div id="gift-modal" class="fixed inset-0 z-[70] flex items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none" aria-hidden="true">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="window.modals.closeGift()"></div>

  <div class="relative bg-white rounded-3xl shadow-2xl max-w-xl w-full overflow-hidden transform transition-all duration-300 scale-95 -rotate-6" id="gift-modal-content">
    <button
      type="button"
      onclick="window.modals.closeGift()"
      class="absolute top-4 right-4 z-10 p-2 rounded-full bg-white/90 hover:bg-white transition-colors shadow-lg"
      aria-label="Close"
      tabindex="0"
    >
      {% render 'icon', icon: 'x', size: 20, class: 'text-gray-600' %}
    </button>

    <div class="relative bg-gradient-to-br from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple p-8 text-center overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        {% for i in (1..12) %}
          <span class="absolute text-white animate-pulse" style="left:{{ i | times: 8 }}%;top:{{ i | times: 7 | plus: 3 }}%;animation-delay:{{ i | times: 0.16 }}s">
            {% render 'icon', icon: 'sparkles', size: 18 %}
          </span>
        {% endfor %}
      </div>
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mb-2 drop-shadow-lg animate-bounce">Congratulations!</h2>
        <p class="text-lg sm:text-xl text-white/95 font-body drop-shadow">Your Gift is Ready!</p>
      </div>
    </div>

    <div class="p-8 bg-gradient-to-br from-purple-50 via-pink-50 to-yellow-50">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple rounded-2xl blur-xl opacity-30 animate-pulse"></div>
        <div class="relative bg-white rounded-2xl p-6 shadow-xl border-4 border-chewteinz-pink">
          <div class="absolute -top-2 -left-2 w-8 h-8 bg-chewteinz-yellow rounded-full shadow-lg"></div>
          <div class="absolute -top-2 -right-2 w-8 h-8 bg-chewteinz-pink rounded-full shadow-lg"></div>
          <div class="absolute -bottom-2 -left-2 w-8 h-8 bg-chewteinz-purple rounded-full shadow-lg"></div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-chewteinz-yellow rounded-full shadow-lg"></div>

          <div class="text-center py-4">
            <p class="text-gray-600 font-body text-sm mb-3">Click to copy your discount code</p>
            <button
              type="button"
              onclick="window.modals.copyGiftCode()"
              class="group relative bg-gradient-to-r from-chewteinz-yellow via-chewteinz-pink to-chewteinz-purple p-1 rounded-xl hover:scale-105 transition-transform duration-200"
              id="gift-copy-btn"
            >
              <div class="bg-white rounded-lg px-8 py-4 flex items-center gap-3">
                <span class="text-3xl sm:text-4xl font-display font-bold bg-gradient-to-r from-chewteinz-purple via-chewteinz-pink to-chewteinz-yellow bg-clip-text text-transparent">CHEWFAN10</span>
                <span id="gift-copy-icon">{% render 'icon', icon: 'copy', size: 24, class: 'text-gray-400 group-hover:text-chewteinz-purple transition-colors' %}</span>
                <span id="gift-check-icon" class="hidden">{% render 'icon', icon: 'check', size: 24, class: 'text-green-500' %}</span>
              </div>
            </button>
            <p id="gift-copied-msg" class="hidden text-green-600 font-body text-sm mt-3 animate-pulse">Code copied to clipboard!</p>
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <div class="bg-white rounded-full px-6 py-3 inline-block shadow-lg">
          <span class="text-chewteinz-purple font-display font-bold text-xl">10% OFF Your First Order</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="confetti-container" class="fixed inset-0 pointer-events-none z-[80] overflow-hidden hidden"></div>
