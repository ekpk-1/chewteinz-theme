[
    {
        "name": "theme_info",
        "theme_name": "ChewTeinz",
        "theme_version": "1.0.0",
        "theme_author": "ChewTeinz",
        "theme_documentation_url": "https://chewteinz.com",
        "theme_support_url": "https://chewteinz.com"
    },
    {
        "name": "Favicon",
        "settings": [
            {
                "type": "header",
                "content": "Favicon"
            },
            {
                "type": "paragraph",
                "content": "Upload a square image (PNG, 32×32px recommended). It appears in browser tabs, bookmarks, and home screen shortcuts."
            },
            {
                "type": "image_picker",
                "id": "favicon",
                "label": "Favicon image"
            }
        ]
    },
    {
        "name": "Klaviyo Integration",
        "settings": [
            {
                "type": "header",
                "content": "Klaviyo Email & SMS Marketing"
            },
            {
                "type": "paragraph",
                "content": "Power the signup popup and back-in-stock notify modal. Use your Public API Key (Site ID) from Klaviyo → Settings → API Keys. List IDs are in Audience → Lists & Segments (6-char code in the list URL)."
            },
            {
                "type": "text",
                "id": "klaviyo_public_key",
                "label": "Klaviyo Public API Key (Site ID)"
            },
            {
                "type": "text",
                "id": "klaviyo_subscribe_list_id",
                "label": "List ID (Signup Popup — early access & 10% off)"
            },
            {
                "type": "text",
                "id": "klaviyo_notify_list_id",
                "label": "List ID (Back-in-Stock Notify Modal)",
                "info": "Can be same as Subscribe list. Back-in-stock signups will include a product preference."
            },
            {
                "type": "header",
                "content": "Signup Popup"
            },
            {
                "type": "image_picker",
                "id": "subscribe_modal_image",
                "label": "Popup image",
                "info": "Full-bleed image on the left panel (desktop). Upload your designed graphic here."
            },
            {
                "type": "checkbox",
                "id": "subscribe_modal_enabled",
                "label": "Show subscribe popup on first visit",
                "default": true
            },
            {
                "type": "range",
                "id": "subscribe_modal_delay",
                "label": "Popup delay (seconds)",
                "min": 3,
                "max": 60,
                "step": 1,
                "default": 10,
                "unit": "s",
                "info": "How long to wait before showing the subscribe modal. Resets when the visitor closes the popup or signs up."
            },
            {
                "type": "checkbox",
                "id": "subscribe_fab_enabled",
                "label": "Show floating signup button",
                "default": true,
                "info": "Fixed button at the bottom-right of the screen to open the signup popup."
            },
            {
                "type": "text",
                "id": "subscribe_fab_label",
                "label": "Floating button label",
                "default": "Get 10% Off"
            }
        ]
    },
    {
        "name": "Supabase Integration",
        "settings": [
            {
                "type": "header",
                "content": "Supabase Settings"
            },
            {
                "type": "paragraph",
                "content": "Used for logging contact form submissions."
            },
            {
                "type": "text",
                "id": "supabase_url",
                "label": "Supabase URL"
            },
            {
                "type": "text",
                "id": "supabase_anon_key",
                "label": "Supabase Anon Key"
            }
        ]
    },
    {
        "name": "Make.com Integration",
        "settings": [
            {
                "type": "header",
                "content": "Make.com Webhook"
            },
            {
                "type": "paragraph",
                "content": "Used for forwarding contact form submissions."
            },
            {
                "type": "text",
                "id": "make_webhook_url",
                "label": "Make.com Webhook URL"
            }
        ]
    }
]